@page "/forgot-password"
@using System.Net.Http.Json
@using PropaneDriver.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Forgot Password</PageTitle>

<h3>Forgot Password</h3>

<div class="container border" style="padding: 20px; max-width: 500px;">
    @if (_submitted)
    {
        <div class="alert alert-success">
            @_message
        </div>
        <button type="button" class="btn btn-primary" @onclick="GoToLogin">Back to Login</button>
    }
    else
    {
        <p>Enter your email address and we'll send you a link to reset your password.</p>
        <EditForm Model="@_dto" OnSubmit="@Submit">
            <div class="form-group mb-3">
                <label for="email">Email</label>
                <InputText type="email" class="form-control" id="email" style="width: 100%; border: inset;" @bind-Value=@_dto.Email />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_busy">
                @(_busy ? "Sending..." : "Send Reset Link")
            </button>
            <button type="button" class="btn btn-link" @onclick="GoToLogin">Cancel</button>
        </EditForm>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mt-3">@_error</div>
        }
    }
</div>

@code {
    private ForgotPasswordDto _dto = new();
    private bool _busy;
    private bool _submitted;
    private string _message = string.Empty;
    private string _error = string.Empty;

    private async Task Submit()
    {
        _busy = true;
        _error = string.Empty;
        try
        {
            var response = await Http.PostAsJsonAsync("api/ForgotPassword", _dto);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<MessageResponse>();
                _message = result?.Message ?? "If that email is registered, a reset link has been sent.";
                _submitted = true;
            }
            else
            {
                _error = "Something went wrong. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoToLogin() => Navigation.NavigateTo("/authentication/login");

    private class MessageResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}
