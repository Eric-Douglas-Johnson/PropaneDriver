@page "/"

<PageTitle>Propane Driver</PageTitle>

<div class="home-wrap">

    <section class="home-hero">
        <h1>Propane Driver</h1>
        <p class="home-tagline">Built for the road. Built by the road.</p>
    </section>

    <div class="home-truck-card">
        <svg viewBox="0 0 480 180" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Futuristic propane bobtail">
            <defs>
                <linearGradient id="tankBody" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#3a4666"/>
                    <stop offset="35%" stop-color="#1a1f33"/>
                    <stop offset="58%" stop-color="#0a0e1c"/>
                    <stop offset="100%" stop-color="#050811"/>
                </linearGradient>
                <linearGradient id="tankSheen" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#7ff1ff" stop-opacity="0"/>
                    <stop offset="46%" stop-color="#7ff1ff" stop-opacity="0"/>
                    <stop offset="50%" stop-color="#7ff1ff" stop-opacity="0.35"/>
                    <stop offset="54%" stop-color="#7ff1ff" stop-opacity="0"/>
                    <stop offset="100%" stop-color="#7ff1ff" stop-opacity="0"/>
                </linearGradient>
                <linearGradient id="cabBody" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#2b3550"/>
                    <stop offset="60%" stop-color="#0f1424"/>
                    <stop offset="100%" stop-color="#050811"/>
                </linearGradient>
                <linearGradient id="windowGlow" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#1e3a8a"/>
                    <stop offset="35%" stop-color="#3b82f6"/>
                    <stop offset="65%" stop-color="#7ff1ff"/>
                    <stop offset="100%" stop-color="#3b82f6"/>
                </linearGradient>
                <radialGradient id="plasma" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#ffffff"/>
                    <stop offset="25%" stop-color="#b8e8ff"/>
                    <stop offset="55%" stop-color="#7ff1ff"/>
                    <stop offset="85%" stop-color="#3b82f6"/>
                    <stop offset="100%" stop-color="#1e3a8a"/>
                </radialGradient>
                <radialGradient id="underglow" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.7"/>
                    <stop offset="40%" stop-color="#3b82f6" stop-opacity="0.25"/>
                    <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
                </radialGradient>
                <linearGradient id="hoverPad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#b8f0ff" stop-opacity="0.95"/>
                    <stop offset="18%" stop-color="#7ff1ff" stop-opacity="0.8"/>
                    <stop offset="55%" stop-color="#3b82f6" stop-opacity="0.5"/>
                    <stop offset="100%" stop-color="#1e3a8a" stop-opacity="0"/>
                </linearGradient>
                <radialGradient id="headlightBeam" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#ffffff"/>
                    <stop offset="30%" stop-color="#b8e8ff"/>
                    <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
                </radialGradient>
                <radialGradient id="flameGrad" cx="50%" cy="55%" r="55%">
                    <stop offset="0%" stop-color="#fff8c0"/>
                    <stop offset="35%" stop-color="#ffb050"/>
                    <stop offset="75%" stop-color="#f07020"/>
                    <stop offset="100%" stop-color="#a02010"/>
                </radialGradient>
                <filter id="softGlow" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="b"/>
                    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <filter id="hardGlow" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="1.4" result="b"/>
                    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
            </defs>

            <!-- Background scanlines -->
            <g opacity="0.1" stroke="#3b82f6" stroke-width="0.4">
                <line x1="0" y1="146" x2="480" y2="146"/>
                <line x1="0" y1="162" x2="480" y2="162"/>
                <line x1="55" y1="138" x2="55" y2="172"/>
                <line x1="175" y1="138" x2="175" y2="172"/>
                <line x1="305" y1="138" x2="305" y2="172"/>
                <line x1="425" y1="138" x2="425" y2="172"/>
            </g>

            <!-- Ambient underglow bloom -->
            <ellipse cx="240" cy="155" rx="240" ry="24" fill="url(#underglow)"/>

            <!-- Hover pads -->
            <g>
                <path d="M 50 130 L 285 130 Q 300 138 290 150 L 60 150 Q 38 144 50 130 Z" fill="url(#hoverPad)"/>
                <path d="M 50 130 L 285 130" stroke="#b8f0ff" stroke-width="1.5" fill="none" filter="url(#hardGlow)"/>
                <path d="M 325 130 L 450 130 Q 466 138 456 150 L 335 150 Q 313 144 325 130 Z" fill="url(#hoverPad)"/>
                <path d="M 325 130 L 450 130" stroke="#b8f0ff" stroke-width="1.5" fill="none" filter="url(#hardGlow)"/>
            </g>

            <!-- Sparks drifting from hover field -->
            <g fill="#7ff1ff" filter="url(#softGlow)">
                <circle cx="80"  cy="158" r="0.9"/>
                <circle cx="150" cy="163" r="0.6"/>
                <circle cx="215" cy="160" r="0.7"/>
                <circle cx="265" cy="166" r="0.5"/>
                <circle cx="365" cy="161" r="0.7"/>
                <circle cx="420" cy="165" r="0.6"/>
            </g>

            <!-- Tank body -->
            <g>
                <rect x="35" y="40" width="265" height="90" rx="45" ry="45" fill="url(#tankBody)" stroke="#3b82f6" stroke-width="1" filter="url(#hardGlow)"/>
                <rect x="35" y="40" width="265" height="90" rx="45" ry="45" fill="url(#tankSheen)"/>
                <line x1="98"  y1="46" x2="98"  y2="124" stroke="#3b82f6" stroke-width="0.9" stroke-opacity="0.7"/>
                <line x1="98"  y1="52" x2="98"  y2="118" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.6"/>
                <line x1="168" y1="46" x2="168" y2="124" stroke="#3b82f6" stroke-width="0.9" stroke-opacity="0.7"/>
                <line x1="168" y1="52" x2="168" y2="118" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.6"/>
                <line x1="238" y1="46" x2="238" y2="124" stroke="#3b82f6" stroke-width="0.9" stroke-opacity="0.7"/>
                <line x1="238" y1="52" x2="238" y2="118" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.6"/>
                <path d="M 70 42 L 268 42"   stroke="#7ff1ff" stroke-width="0.6" stroke-opacity="0.45"/>
                <path d="M 70 128 L 268 128" stroke="#7ff1ff" stroke-width="0.7" stroke-opacity="0.6" filter="url(#hardGlow)"/>
            </g>

            <!-- Plasma viewport -->
            <g>
                <circle cx="133" cy="85" r="22" fill="#0a0e1c" stroke="#3b82f6" stroke-width="1.4"/>
                <circle cx="133" cy="85" r="18" fill="url(#plasma)"/>
                <circle cx="133" cy="85" r="14" fill="none" stroke="#b8e8ff" stroke-width="0.4" stroke-opacity="0.7"/>
                <circle cx="133" cy="85" r="10" fill="none" stroke="#b8e8ff" stroke-width="0.3" stroke-opacity="0.5"/>
                <ellipse cx="128" cy="79" rx="6" ry="3" fill="#ffffff" fill-opacity="0.55"/>
            </g>

            <!-- Flame energy badge -->
            <g transform="translate(208, 85)">
                <circle cx="0" cy="0" r="18" fill="#0a0e1c" stroke="#3b82f6" stroke-width="0.9"/>
                <circle cx="0" cy="2" r="13" fill="url(#flameGrad)" opacity="0.85" filter="url(#hardGlow)"/>
                <path d="M 0 -10 Q -6 -4 -7 4 Q -7 10 0 10 Q 7 10 7 4 Q 6 -4 0 -10 Z" fill="#ffd060"/>
                <path d="M 0 -5  Q -4 -1 -4 4 Q -3 8 0 8  Q 3 8 4 4 Q 4 -1 0 -5  Z" fill="#fff8c0"/>
            </g>

            <!-- "PROPANE" wordmark -->
            <text x="208" y="120" text-anchor="middle" font-family="Consolas, 'Courier New', monospace" font-size="6" fill="#7ff1ff" letter-spacing="2.5" filter="url(#hardGlow)">PROPANE</text>

            <!-- Top manifold / sensor array -->
            <g>
                <rect x="123" y="32" width="48" height="9" fill="#1a1f33" stroke="#3b82f6" stroke-width="0.5"/>
                <rect x="130" y="22" width="4" height="10" fill="#2b3550"/>
                <rect x="145" y="18" width="4" height="14" fill="#2b3550"/>
                <rect x="160" y="22" width="4" height="10" fill="#2b3550"/>
                <circle cx="132" cy="22" r="1.6" fill="#7ff1ff" filter="url(#hardGlow)"/>
                <circle cx="147" cy="18" r="1.6" fill="#7ff1ff" filter="url(#hardGlow)"/>
                <circle cx="162" cy="22" r="1.6" fill="#7ff1ff" filter="url(#hardGlow)"/>
            </g>

            <!-- Antenna -->
            <g>
                <line x1="248" y1="40" x2="248" y2="14" stroke="#3b82f6" stroke-width="0.8"/>
                <circle cx="248" cy="12" r="1.8" fill="#ff8030" filter="url(#hardGlow)"/>
            </g>

            <!-- Pump / connector -->
            <g>
                <rect x="295" y="55" width="32" height="75" fill="url(#cabBody)" stroke="#3b82f6" stroke-width="0.6"/>
                <line x1="301" y1="66" x2="321" y2="66" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.55"/>
                <line x1="301" y1="72" x2="321" y2="72" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.55"/>
                <line x1="301" y1="78" x2="321" y2="78" stroke="#7ff1ff" stroke-width="0.4" stroke-opacity="0.55"/>
                <rect x="301" y="92" width="20" height="10" fill="#0a0e1c" stroke="#3b82f6" stroke-width="0.4"/>
                <rect x="303" y="94" width="16" height="2.5" fill="#7ff1ff" filter="url(#hardGlow)"/>
                <rect x="303" y="98" width="10" height="1.5" fill="#3b82f6"/>
                <line x1="301" y1="115" x2="321" y2="115" stroke="#3b82f6" stroke-width="0.4" stroke-opacity="0.6"/>
                <line x1="301" y1="120" x2="321" y2="120" stroke="#3b82f6" stroke-width="0.4" stroke-opacity="0.6"/>
            </g>

            <!-- Cab body -->
            <g>
                <path d="M 330 45 L 438 45 L 460 70 L 460 130 L 330 130 Z" fill="url(#cabBody)" stroke="#3b82f6" stroke-width="1" filter="url(#hardGlow)"/>
                <path d="M 330 45 L 438 45" stroke="#7ff1ff" stroke-width="0.6" stroke-opacity="0.6"/>
                <path d="M 338 58 L 432 58 L 452 80 L 452 92 L 338 92 Z" fill="url(#windowGlow)"/>
                <path d="M 338 58 L 432 58 L 452 80 L 452 92 L 338 92 Z" fill="none" stroke="#0a0e1c" stroke-width="1.2"/>
                <line x1="390" y1="58" x2="390" y2="92" stroke="#0a0e1c" stroke-width="0.9"/>
                <path d="M 358 60 L 348 90" stroke="#ffffff" stroke-width="1.6" stroke-opacity="0.3"/>
                <path d="M 368 60 L 358 90" stroke="#ffffff" stroke-width="0.8" stroke-opacity="0.22"/>
                <line x1="338" y1="102" x2="450" y2="102" stroke="#7ff1ff" stroke-width="1" filter="url(#hardGlow)"/>
                <line x1="380" y1="102" x2="380" y2="130" stroke="#0a0e1c" stroke-width="1.1"/>
                <line x1="386" y1="115" x2="394" y2="115" stroke="#3b82f6" stroke-width="1.1" filter="url(#hardGlow)"/>
                <rect x="324" y="50" width="6" height="11" fill="#0a0e1c" stroke="#7ff1ff" stroke-width="0.5" filter="url(#hardGlow)"/>
            </g>

            <!-- Headlight -->
            <g>
                <circle cx="456" cy="106" r="14" fill="url(#headlightBeam)" filter="url(#softGlow)"/>
                <rect x="446" y="104" width="20" height="4" rx="2" fill="#ffffff" filter="url(#hardGlow)"/>
                <rect x="447" y="105" width="18" height="2" rx="1" fill="#b8e8ff"/>
            </g>

            <!-- Front vent / energy collector -->
            <g>
                <rect x="448" y="116" width="14" height="2" fill="#7ff1ff" filter="url(#hardGlow)"/>
                <rect x="448" y="121" width="14" height="2" fill="#3b82f6"/>
            </g>

            <!-- Ambient particles -->
            <g fill="#7ff1ff">
                <circle cx="22"  cy="32" r="0.6" opacity="0.65"/>
                <circle cx="62"  cy="20" r="0.4" opacity="0.5"/>
                <circle cx="380" cy="25" r="0.5" opacity="0.6"/>
                <circle cx="455" cy="38" r="0.4" opacity="0.5"/>
                <circle cx="432" cy="16" r="0.6" opacity="0.7"/>
                <circle cx="15"  cy="85" r="0.4" opacity="0.5"/>
                <circle cx="470" cy="60" r="0.5" opacity="0.6"/>
            </g>
        </svg>
    </div>

    <div class="home-card">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery
            drivers manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu or
            <a href="authentication/login" class="home-link">get started here &rarr;</a>
        </p>
    </div>

</div>
