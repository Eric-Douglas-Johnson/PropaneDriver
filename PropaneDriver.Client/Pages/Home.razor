@page "/"
@inject HttpClient Http

<PageTitle>Propane Driver</PageTitle>

<div class="home-wrap">

    <section class="home-hero">
        <h1>Propane Driver</h1>
        <p class="home-tagline">Built for the road. Built by the road.</p>
    </section>

    @if (_fuelPrices is { Count: > 0 })
    {
        <div class="home-info-card">
            <div class="home-info-header">
                <h2>Fuel Market Snapshot</h2>
                <span class="home-info-source">U.S. EIA weekly national averages</span>
            </div>
            <div class="home-price-grid">
                @foreach (var fuelPrice in _fuelPrices)
                {
                    <div class="home-price-tile">
                        <span class="home-price-fuel">@fuelPrice.FuelName</span>
                        <span class="home-price-value">
                            $@fuelPrice.PricePerGallon.ToString("0.00")<span class="home-price-unit">/gal</span>
                        </span>
                        @if (fuelPrice.ChangeFromPriorWeek is decimal weeklyChange)
                        {
                            @if (weeklyChange > 0)
                            {
                                <span class="home-price-change home-price-up">&#9650; @FormatChange(weeklyChange) vs prior week</span>
                            }
                            else if (weeklyChange < 0)
                            {
                                <span class="home-price-change home-price-down">&#9660; @FormatChange(weeklyChange) vs prior week</span>
                            }
                            else
                            {
                                <span class="home-price-change home-price-flat">unchanged from prior week</span>
                            }
                        }
                        <span class="home-price-date">week of @fuelPrice.PriceDate.ToString("MMM d, yyyy")</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="home-info-card">
        <div class="home-info-header">
            <h2>Delivery Season Outlook</h2>
        </div>
        <div class="home-season">
            <p class="home-season-status">
                <span class="home-season-dot @_seasonDotClass"></span>@_seasonHeadline
            </p>
            <p class="home-season-detail">@_seasonDetail</p>
            <p class="home-season-tip"><strong>On the job:</strong> @_dailyTip</p>
        </div>
    </div>

    <div class="home-card">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery
            drivers manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu or
            <a href="authentication/login" class="home-link">get started here &rarr;</a>
        </p>
    </div>

</div>

@code {
    private List<FuelPriceDto>? _fuelPrices;

    private string _seasonHeadline = string.Empty;
    private string _seasonDetail = string.Empty;
    private string _seasonDotClass = string.Empty;
    private string _dailyTip = string.Empty;

    // Rotates one tip per day so the panel doesn't go stale for daily users.
    private static readonly string[] DriverTips =
    {
        "Walk the line on every fill — regulator, connections, tank condition — not just the first visit.",
        "Never fill a stationary tank past 80%; liquid propane needs that headspace to expand.",
        "An out-of-gas call means a documented leak check before anything gets relit.",
        "Cold weather drops tank pressure — budget extra time per stop when temps go below zero.",
        "Bleed the hose down before disconnecting in freezing weather; wet fittings ice up fast.",
        "When a property has more than one tank, match the tank serial to the ticket before pumping.",
        "Three points of contact on icy tank steps and the truck deck — every time.",
        "Off-season is the time to flag tanks with worn paint, bad gauges, or buried regulators for service.",
    };

    protected override void OnInitialized()
    {
        ComputeSeasonOutlook(DateTime.Today);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var snapshot = await Http.GetFromJsonAsync<FuelPriceSnapshotDto>("api/fuel-prices");
            _fuelPrices = snapshot?.Prices;
        }
        catch
        {
            // Price strip is informational only — render the page without it.
            _fuelPrices = null;
        }
    }

    private void ComputeSeasonOutlook(DateTime today)
    {
        _dailyTip = DriverTips[today.DayOfYear % DriverTips.Length];

        // Heating season runs October 1 through March 31.
        if (today.Month is >= 4 and <= 9)
        {
            var seasonStart = new DateTime(today.Year, 10, 1);
            _seasonHeadline = "Off-season — summer-fill programs and tank sets";
            _seasonDetail = $"Heating season begins October 1 — {(seasonStart - today).Days} days away.";
            _seasonDotClass = "home-season-off";
            return;
        }

        var seasonEnd = new DateTime(today.Month >= 10 ? today.Year + 1 : today.Year, 3, 31);
        var daysLeft = (seasonEnd - today).Days;

        if (today.Month is 10 or 11)
        {
            _seasonHeadline = "Early heating season — deliveries ramping up";
            _seasonDotClass = "home-season-early";
        }
        else if (today.Month == 3)
        {
            _seasonHeadline = "Late heating season — demand winding down";
            _seasonDotClass = "home-season-late";
        }
        else
        {
            _seasonHeadline = "Peak heating season — highest demand of the year";
            _seasonDotClass = "home-season-peak";
        }

        _seasonDetail = $"{daysLeft} days left in the heating season (ends March 31).";
    }

    // Week-over-week change reads better in cents: "+3.5¢" instead of "$0.035".
    private static string FormatChange(decimal weeklyChange)
        => $"{Math.Abs(weeklyChange) * 100:0.#}¢";
}
