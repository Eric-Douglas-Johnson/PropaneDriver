@page "/"
@inject IJSRuntime JS

<PageTitle>Propane Driver</PageTitle>

<div class="container" style="padding: 20px;">
    <h1>Propane Driver</h1>
    <h3>The delivery driver utility built for drivers, by drivers.</h3>

    <div style="font-size: 18px; margin-top: 20px;">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery drivers
            manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu, then register for an account.
        </p>
    </div>

    <hr />
    <h5>GPS Test</h5>
    <button class="btn btn-primary" @onclick="GetLocation" disabled="@_loading">
        @(_loading ? "Getting location..." : "Get Current GPS Location")
    </button>

    @if (_timerRunning)
    {
        <button class="btn btn-danger ms-2" @onclick="StopTimer">
            Stop Timer
        </button>
        <span class="ms-3" style="font-size: 1.1rem;">@FormatElapsed(_elapsed)</span>
    }

    @if (!string.IsNullOrEmpty(_locationResult))
    {
        <div class="mt-3 p-3" style="background-color: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 6px;">
            <span>@_locationResult</span>
        </div>
    }

    @if (_timerResult is not null)
    {
        <div class="mt-3 p-3" style="background-color: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 6px;">
            <span>Elapsed Time: @FormatElapsed(_timerResult.Value)</span>
        </div>
    }
</div>

@code {
    private bool _loading;
    private string _locationResult = string.Empty;
    private bool _timerRunning;
    private DateTime _timerStart;
    private TimeSpan _elapsed;
    private TimeSpan? _timerResult;
    private System.Threading.Timer? _ticker;

    private async Task GetLocation()
    {
        _loading = true;
        _locationResult = string.Empty;
        _timerResult = null;
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<double[]>("getDeviceLocation");
            var lat = coords[0];
            var lon = coords[1];
            _locationResult = $"Latitude: {lat}, Longitude: {lon}";
            await JS.InvokeVoidAsync("alert", $"GPS Location\nLatitude: {lat}\nLongitude: {lon}");

            // Start the timer after GPS is acquired
            _timerStart = DateTime.Now;
            _elapsed = TimeSpan.Zero;
            _timerRunning = true;
            _ticker = new System.Threading.Timer(Tick, null, 0, 100);
        }
        catch (Exception ex)
        {
            _locationResult = $"Error: {ex.Message}";
            await JS.InvokeVoidAsync("alert", $"GPS Error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void Tick(object? state)
    {
        _elapsed = DateTime.Now - _timerStart;
        InvokeAsync(StateHasChanged);
    }

    private void StopTimer()
    {
        _ticker?.Dispose();
        _ticker = null;
        _timerRunning = false;
        _timerResult = _elapsed;
    }

    private static string FormatElapsed(TimeSpan ts)
    {
        if (ts.TotalHours >= 1)
            return ts.ToString(@"h\:mm\:ss\.f");
        if (ts.TotalMinutes >= 1)
            return ts.ToString(@"m\:ss\.f");
        return ts.ToString(@"s\.ff") + "s";
    }

    public void Dispose()
    {
        _ticker?.Dispose();
    }
}
