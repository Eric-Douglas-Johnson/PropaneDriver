@page "/"

<PageTitle>Propane Driver</PageTitle>

<div class="home-wrap">

    <section class="home-hero">
        <h1>Propane Driver</h1>
        <p class="home-tagline">Built for the road. Built by the road.</p>
    </section>

    <div class="home-truck-card">
        <svg viewBox="0 0 520 205" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Propane delivery truck">
            <!-- Ground shadow -->
            <ellipse cx="260" cy="201" rx="210" ry="6" fill="#141428"/>
            <!-- Chassis frame -->
            <rect x="40" y="148" width="432" height="13" rx="3" fill="#0f1e3a"/>
            <!-- Tank rear end-cap -->
            <ellipse cx="52" cy="107" rx="20" ry="43" fill="#22498c"/>
            <!-- Tank body -->
            <rect x="52" y="64" width="284" height="86" fill="#1a3d7a"/>
            <!-- Tank front end-cap -->
            <ellipse cx="336" cy="107" rx="20" ry="43" fill="#142d5e"/>
            <!-- Tank top sheen -->
            <rect x="52" y="67" width="284" height="18" fill="#2e66c8" opacity="0.35"/>
            <!-- Tank bottom shadow -->
            <rect x="52" y="132" width="284" height="18" fill="#08121e" opacity="0.35"/>
            <!-- Tank accent pin-stripes -->
            <rect x="52" y="96" width="284" height="2.5" fill="#3b82f6" opacity="0.28"/>
            <rect x="52" y="115" width="284" height="2.5" fill="#3b82f6" opacity="0.28"/>
            <!-- Mounting strap 1 -->
            <rect x="162" y="62" width="8" height="88" rx="2" fill="#091525"/>
            <!-- Mounting strap 2 -->
            <rect x="252" y="62" width="8" height="88" rx="2" fill="#091525"/>
            <!-- Valve manifold -->
            <rect x="194" y="55" width="40" height="11" rx="3" fill="#0e1b35"/>
            <rect x="202" y="46" width="24" height="11" rx="2" fill="#0c1630"/>
            <ellipse cx="214" cy="44" rx="6" ry="4" fill="#0c1630" stroke="#3b82f6" stroke-width="1.5"/>
            <!-- PROPANE label -->
            <text x="194" y="113" font-family="Arial Black, Arial, sans-serif" font-size="14" font-weight="900" fill="#4a8fd4" letter-spacing="2.5">PROPANE</text>
            <!-- Hazmat placard -->
            <polygon points="93,122 107,136 93,150 79,136" fill="#c42020"/>
            <polygon points="93,128 89.5,136 96.5,136" fill="white" opacity="0.9"/>
            <text x="93" y="147" text-anchor="middle" font-size="7" font-weight="bold" fill="white" opacity="0.9">2</text>
            <!-- Tail lights -->
            <rect x="37" y="78" width="8" height="14" rx="2" fill="#cc1c1c"/>
            <rect x="37" y="96" width="8" height="10" rx="2" fill="#8a1414"/>
            <!-- Cab toolbox step -->
            <rect x="334" y="119" width="20" height="30" rx="2" fill="#0c1528"/>
            <!-- Cab main body -->
            <rect x="350" y="63" width="128" height="85" rx="4" fill="#1a3d7a"/>
            <!-- Cab accent stripe -->
            <rect x="350" y="102" width="128" height="12" fill="#2e66c8" opacity="0.2"/>
            <!-- A-pillar / windshield slope -->
            <polygon points="453,63 473,63 473,92 453,82" fill="#12284f"/>
            <!-- Windshield glass -->
            <polygon points="455,65 470,65 470,90 455,80" fill="#1e50a8" opacity="0.5"/>
            <!-- Side window -->
            <rect x="358" y="72" width="88" height="34" rx="3" fill="#1e50a8" opacity="0.48"/>
            <rect x="358" y="72" width="88" height="34" rx="3" fill="none" stroke="#2e5fb8" stroke-width="1.5"/>
            <!-- Door line -->
            <line x1="414" y1="70" x2="414" y2="148" stroke="#091525" stroke-width="1.5"/>
            <!-- Door handle -->
            <rect x="420" y="116" width="14" height="4" rx="2" fill="#4a8fd4"/>
            <!-- Front face -->
            <rect x="473" y="67" width="11" height="81" rx="2" fill="#12284f"/>
            <!-- Headlight -->
            <rect x="470" y="86" width="11" height="18" rx="2" fill="#ffe060"/>
            <rect x="473" y="88" width="5" height="14" rx="1" fill="#fff4a0" opacity="0.55"/>
            <!-- Turn/running light -->
            <rect x="470" y="107" width="11" height="8" rx="2" fill="#ff8020" opacity="0.8"/>
            <!-- Front bumper -->
            <rect x="463" y="138" width="25" height="12" rx="3" fill="#0e1b35"/>
            <rect x="467" y="148" width="18" height="4" rx="1" fill="#162040"/>
            <!-- Exhaust stack -->
            <rect x="366" y="24" width="9" height="42" rx="3" fill="#192848"/>
            <ellipse cx="370" cy="23" rx="5.5" ry="3.5" fill="#0c1630"/>
            <ellipse cx="369" cy="15" rx="5" ry="4" fill="#2a3a5a" opacity="0.3"/>
            <ellipse cx="372" cy="9" rx="3.5" ry="3" fill="#2a3a5a" opacity="0.18"/>
            <!-- Flame badge on door -->
            <circle cx="382" cy="110" r="11" fill="#0f1e3a" stroke="#1c3670" stroke-width="1.5"/>
            <polygon points="382,103 378,114 386,114" fill="#f07020" opacity="0.9"/>
            <polygon points="382,106 380,112.5 384,112.5" fill="#ffaa40" opacity="0.7"/>
            <!-- Front wheel -->
            <circle cx="432" cy="175" r="26" fill="#0d1117" stroke="#1c3a6a" stroke-width="4"/>
            <circle cx="432" cy="175" r="16" fill="#131d2e" stroke="#264c8c" stroke-width="2"/>
            <line x1="432" y1="160" x2="432" y2="167" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="432" y1="183" x2="432" y2="190" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="417" y1="175" x2="424" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="440" y1="175" x2="447" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <circle cx="432" cy="175" r="5" fill="#3b82f6"/>
            <!-- Rear tandem wheel 1 -->
            <circle cx="138" cy="175" r="26" fill="#0d1117" stroke="#1c3a6a" stroke-width="4"/>
            <circle cx="138" cy="175" r="16" fill="#131d2e" stroke="#264c8c" stroke-width="2"/>
            <line x1="138" y1="160" x2="138" y2="167" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="138" y1="183" x2="138" y2="190" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="123" y1="175" x2="130" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="146" y1="175" x2="153" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <circle cx="138" cy="175" r="5" fill="#3b82f6"/>
            <!-- Rear tandem wheel 2 -->
            <circle cx="192" cy="175" r="26" fill="#0d1117" stroke="#1c3a6a" stroke-width="4"/>
            <circle cx="192" cy="175" r="16" fill="#131d2e" stroke="#264c8c" stroke-width="2"/>
            <line x1="192" y1="160" x2="192" y2="167" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="192" y1="183" x2="192" y2="190" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="177" y1="175" x2="184" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <line x1="200" y1="175" x2="207" y2="175" stroke="#264c8c" stroke-width="1.5"/>
            <circle cx="192" cy="175" r="5" fill="#3b82f6"/>
        </svg>
    </div>

    <div class="home-card">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery
            drivers manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu or
            <a href="authentication/login" class="home-link">get started here &rarr;</a>
        </p>
    </div>

</div>
