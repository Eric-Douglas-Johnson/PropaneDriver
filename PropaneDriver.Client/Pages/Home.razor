@page "/"
@inject IJSRuntime JS

<PageTitle>Propane Driver</PageTitle>

<div class="container" style="padding: 20px;">
    <h1>Propane Driver</h1>
    <h3>The delivery driver utility built for drivers, by drivers.</h3>

    <div style="font-size: 18px; margin-top: 20px;">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery drivers
            manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu, then register for an account.
        </p>
    </div>

    <hr />
    <h5>GPS Test</h5>
    <button class="btn btn-primary" @onclick="GetLocation" disabled="@_loading">
        @(_loading ? "Getting location..." : "Get Current GPS Location")
    </button>

    @if (!string.IsNullOrEmpty(_locationResult))
    {
        <div class="mt-3 p-3" style="background-color: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 6px;">
            <span>@_locationResult</span>
        </div>
    }
</div>

@code {
    private bool _loading;
    private string _locationResult = string.Empty;

    private async Task GetLocation()
    {
        _loading = true;
        _locationResult = string.Empty;
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<double[]>("getDeviceLocation");
            var lat = coords[0];
            var lon = coords[1];
            _locationResult = $"Latitude: {lat}, Longitude: {lon}";
            await JS.InvokeVoidAsync("alert", $"GPS Location\nLatitude: {lat}\nLongitude: {lon}");
        }
        catch (Exception ex)
        {
            _locationResult = $"Error: {ex.Message}";
            await JS.InvokeVoidAsync("alert", $"GPS Error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
