@page "/"

<PageTitle>Propane Driver</PageTitle>

<div class="home-wrap">

    <section class="home-hero">
        <h1>Propane Driver</h1>
        <p class="home-tagline">Built for the road. Built by the road.</p>
    </section>

    <div class="home-truck-card">
        <svg viewBox="0 0 80 33" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges" role="img" aria-label="Propane delivery truck (8-bit pixel art)">
            <!-- Exhaust stack -->
            <rect x="50" y="2" width="2" height="8" fill="#192848"/>
            <rect x="49" y="2" width="1" height="1" fill="#0c1630"/>
            <rect x="52" y="2" width="1" height="1" fill="#0c1630"/>
            <rect x="50" y="1" width="2" height="1" fill="#0c1630"/>

            <!-- Valve manifold on top of tank -->
            <rect x="22" y="5" width="6" height="3" fill="#0e1b35"/>
            <rect x="24" y="4" width="2" height="1" fill="#0c1630"/>

            <!-- TANK silhouette with stair-stepped end caps -->
            <rect x="10" y="8"  width="36" height="1" fill="#3b6fc6"/>
            <rect x="8"  y="9"  width="38" height="1" fill="#3b6fc6"/>
            <rect x="6"  y="10" width="40" height="1" fill="#2a5db8"/>
            <rect x="5"  y="11" width="41" height="1" fill="#2a5db8"/>
            <rect x="4"  y="12" width="42" height="3" fill="#2a5db8"/>
            <rect x="4"  y="15" width="42" height="1" fill="#4a8fd4"/>
            <rect x="4"  y="16" width="42" height="2" fill="#2a5db8"/>
            <rect x="5"  y="18" width="41" height="1" fill="#1a3d7a"/>
            <rect x="6"  y="19" width="40" height="1" fill="#1a3d7a"/>
            <rect x="8"  y="20" width="38" height="1" fill="#142d5e"/>
            <rect x="10" y="21" width="36" height="1" fill="#142d5e"/>

            <!-- Mounting straps -->
            <rect x="17" y="8" width="1" height="14" fill="#091525"/>
            <rect x="33" y="8" width="1" height="14" fill="#091525"/>

            <!-- Flame badge on tank side -->
            <rect x="26" y="11" width="1" height="1" fill="#ffaa40"/>
            <rect x="25" y="12" width="3" height="1" fill="#ffaa40"/>
            <rect x="24" y="13" width="5" height="1" fill="#f07020"/>
            <rect x="24" y="14" width="5" height="1" fill="#f07020"/>
            <rect x="26" y="14" width="1" height="1" fill="#ffe060"/>
            <rect x="25" y="15" width="3" height="1" fill="#f07020"/>

            <!-- Hazmat placard (diamond) at rear of tank -->
            <rect x="12" y="13" width="1" height="1" fill="#c42020"/>
            <rect x="11" y="14" width="3" height="1" fill="#c42020"/>
            <rect x="10" y="15" width="5" height="1" fill="#c42020"/>
            <rect x="11" y="16" width="3" height="1" fill="#c42020"/>
            <rect x="12" y="17" width="1" height="1" fill="#c42020"/>
            <rect x="12" y="15" width="1" height="1" fill="#ffd860"/>

            <!-- Tail lights -->
            <rect x="2" y="12" width="2" height="2" fill="#cc1c1c"/>
            <rect x="2" y="15" width="2" height="2" fill="#8a1414"/>

            <!-- Toolbox / step between tank and cab -->
            <rect x="46" y="14" width="2" height="8" fill="#0c1528"/>

            <!-- CAB body -->
            <rect x="48" y="10" width="22" height="12" fill="#2a5db8"/>
            <rect x="48" y="10" width="22" height="1" fill="#3b6fc6"/>
            <rect x="48" y="21" width="22" height="1" fill="#1a3d7a"/>

            <!-- Side window glass -->
            <rect x="50" y="12" width="14" height="5" fill="#6ba8e8"/>
            <!-- Window frame -->
            <rect x="49" y="11" width="16" height="1" fill="#0c1630"/>
            <rect x="49" y="17" width="16" height="1" fill="#0c1630"/>
            <rect x="49" y="11" width="1" height="7" fill="#0c1630"/>
            <rect x="64" y="11" width="1" height="7" fill="#0c1630"/>
            <!-- Window mid-divider -->
            <rect x="57" y="12" width="1" height="5" fill="#0c1630"/>

            <!-- Door line and handle -->
            <rect x="58" y="18" width="1" height="4" fill="#0c1630"/>
            <rect x="60" y="20" width="2" height="1" fill="#4a8fd4"/>

            <!-- Hood / front face -->
            <rect x="70" y="13" width="3" height="7" fill="#1a3d7a"/>
            <rect x="70" y="13" width="3" height="1" fill="#2a5db8"/>
            <!-- Headlight -->
            <rect x="72" y="15" width="2" height="2" fill="#ffe060"/>
            <!-- Turn light -->
            <rect x="72" y="18" width="2" height="1" fill="#ff8020"/>

            <!-- Front bumper -->
            <rect x="70" y="20" width="6" height="2" fill="#0e1b35"/>

            <!-- Chassis frame -->
            <rect x="4" y="22" width="72" height="2" fill="#0c1630"/>

            <!-- WHEELS — chunky 7x7 pixel circles -->
            <!-- Rear tandem wheel 1 (cx=12, cy=26) -->
            <rect x="11" y="23" width="3" height="1" fill="#0d1117"/>
            <rect x="10" y="24" width="5" height="1" fill="#0d1117"/>
            <rect x="9"  y="25" width="7" height="3" fill="#0d1117"/>
            <rect x="10" y="28" width="5" height="1" fill="#0d1117"/>
            <rect x="11" y="29" width="3" height="1" fill="#0d1117"/>
            <rect x="11" y="25" width="3" height="3" fill="#3b82f6"/>
            <rect x="12" y="26" width="1" height="1" fill="#ffe060"/>

            <!-- Rear tandem wheel 2 (cx=22, cy=26) -->
            <rect x="21" y="23" width="3" height="1" fill="#0d1117"/>
            <rect x="20" y="24" width="5" height="1" fill="#0d1117"/>
            <rect x="19" y="25" width="7" height="3" fill="#0d1117"/>
            <rect x="20" y="28" width="5" height="1" fill="#0d1117"/>
            <rect x="21" y="29" width="3" height="1" fill="#0d1117"/>
            <rect x="21" y="25" width="3" height="3" fill="#3b82f6"/>
            <rect x="22" y="26" width="1" height="1" fill="#ffe060"/>

            <!-- Front wheel (cx=66, cy=26) -->
            <rect x="65" y="23" width="3" height="1" fill="#0d1117"/>
            <rect x="64" y="24" width="5" height="1" fill="#0d1117"/>
            <rect x="63" y="25" width="7" height="3" fill="#0d1117"/>
            <rect x="64" y="28" width="5" height="1" fill="#0d1117"/>
            <rect x="65" y="29" width="3" height="1" fill="#0d1117"/>
            <rect x="65" y="25" width="3" height="3" fill="#3b82f6"/>
            <rect x="66" y="26" width="1" height="1" fill="#ffe060"/>

            <!-- Ground shadow -->
            <rect x="6"  y="31" width="68" height="1" fill="#141428" opacity="0.75"/>
            <rect x="10" y="32" width="60" height="1" fill="#141428" opacity="0.4"/>
        </svg>
    </div>

    <div class="home-card">
        <p>
            Welcome to PropaneDriver — the app designed to help Class A and B propane delivery
            drivers manage their daily routes, track deliveries, and stay organized on the road.
        </p>
        <p>
            If this is your first time here, click <strong>Login</strong> in the menu or
            <a href="authentication/login" class="home-link">get started here &rarr;</a>
        </p>
    </div>

    <p class="home-photo-credit">
        Hero photo: <a href="https://commons.wikimedia.org/wiki/File:Propane_delivery_truck.jpg" target="_blank" rel="noopener">"Propane delivery truck"</a>
        by Hustvedt,
        <a href="https://creativecommons.org/licenses/by-sa/3.0/" target="_blank" rel="noopener">CC BY-SA 3.0</a>.
    </p>

</div>
