@page "/reset-password"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.WebUtilities
@using PropaneDriver.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Reset Password</PageTitle>

<h3>Reset Password</h3>

<div class="container border" style="padding: 20px; max-width: 500px;">
    @if (string.IsNullOrEmpty(_dto.Token))
    {
        <div class="alert alert-danger">
            Missing or invalid reset token. Please request a new password reset link.
        </div>
        <button type="button" class="btn btn-primary" @onclick="GoToForgot">Request New Link</button>
    }
    else if (_success)
    {
        <div class="alert alert-success">
            Your password has been reset successfully. You can now log in with your new password.
        </div>
        <button type="button" class="btn btn-primary" @onclick="GoToLogin">Go to Login</button>
    }
    else
    {
        <EditForm Model="@_dto" OnSubmit="@Submit">
            <div class="form-group mb-3">
                <label for="new-password">New Password</label>
                <InputText type="password" class="form-control" id="new-password" style="width: 100%; border: inset;" @bind-Value=@_dto.NewPassword />
            </div>
            <div class="form-group mb-3">
                <label for="confirm-password">Confirm Password</label>
                <InputText type="password" class="form-control" id="confirm-password" style="width: 100%; border: inset;" @bind-Value=@_confirmPassword />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_busy">
                @(_busy ? "Resetting..." : "Reset Password")
            </button>
        </EditForm>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mt-3">@_error</div>
        }
    }
</div>

@code {
    private ResetPasswordDto _dto = new();
    private string _confirmPassword = string.Empty;
    private bool _busy;
    private bool _success;
    private string _error = string.Empty;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var token))
        {
            _dto.Token = token!;
        }
    }

    private async Task Submit()
    {
        _error = string.Empty;

        if (_dto.NewPassword.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return;
        }

        if (_dto.NewPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _busy = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/ResetPassword", _dto);
            if (response.IsSuccessStatusCode)
            {
                _success = true;
            }
            else
            {
                var result = await response.Content.ReadFromJsonAsync<MessageResponse>();
                _error = result?.Message ?? "Failed to reset password.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoToLogin() => Navigation.NavigateTo("/authentication/login");
    private void GoToForgot() => Navigation.NavigateTo("/forgot-password");

    private class MessageResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}
