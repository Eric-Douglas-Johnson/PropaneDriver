@page "/navigation"
@using PropaneDriver.Client.Services
@inject GeolocationService GeolocationService
@inject GeocodingService Geocoder
@inject Microsoft.JSInterop.IJSRuntime JS
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

@code {
    [SupplyParameterFromQuery(Name = "destination")]
    public string? DestinationQuery { get; set; }
}

<PageTitle>Navigation</PageTitle>

<div class="nav-page">
    <div class="nav-header">
        <input type="text" class="form-control destination-input" placeholder="Destination address"
               value="@_destination" @oninput="OnDestinationInput" />
        <div class="nav-buttons">
            <button class="btn btn-primary" @onclick="GetDirections" disabled="@(_routing || string.IsNullOrWhiteSpace(_destination))">
                @(_routing ? "Routing…" : "Get Directions")
            </button>
            <button class="btn btn-outline-secondary" @onclick="OpenInGoogleMaps" disabled="@string.IsNullOrWhiteSpace(_destination)">
                Open in Maps
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="nav-status">@_status</div>
    }

    <div class="nav-map">
        <div id="leaflet-map"></div>
    </div>
</div>

@code {
    private const double DefaultLat = 47.4273;
    private const double DefaultLon = -92.9378;

    private string _destination = string.Empty;
    private string _fullDestination = string.Empty;
    private string? _status;
    private bool _mapInitialized;
    private bool _routing;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the Leaflet map
            var lat = GeolocationService.CurrentLatitude;
            var lon = GeolocationService.CurrentLongitude;
            if (lat == 0 && lon == 0) { lat = DefaultLat; lon = DefaultLon; }

            await JS.InvokeVoidAsync("navMapInit", "leaflet-map", lat, lon, 13);
            _mapInitialized = true;

            // Subscribe to GPS updates
            GeolocationService.OnPositionChanged += HandlePositionChanged;

            if (!GeolocationService.IsWatching)
            {
                await GeolocationService.StartWatchingAsync();
            }

            // If arrived with a destination query, auto-route
            if (!string.IsNullOrWhiteSpace(DestinationQuery))
            {
                _fullDestination = DestinationQuery;
                var firstComma = DestinationQuery.IndexOf(',');
                _destination = firstComma > 0 ? DestinationQuery[..firstComma].Trim() : DestinationQuery;
                StateHasChanged();
                await FetchAndDrawRoute();
            }
        }
    }

    private async void HandlePositionChanged(double lat, double lon, double accuracy)
    {
        if (!_mapInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("navMapUpdateDriver", lat, lon);
        }
        catch { }
    }

    private void OnDestinationInput(ChangeEventArgs e)
    {
        _destination = e.Value?.ToString() ?? string.Empty;
        _fullDestination = string.Empty;
    }

    private string RoutingDestination =>
        !string.IsNullOrWhiteSpace(_fullDestination) ? _fullDestination : _destination;

    private async Task GetDirections()
    {
        await FetchAndDrawRoute();
    }

    private async Task FetchAndDrawRoute()
    {
        if (string.IsNullOrWhiteSpace(RoutingDestination)) return;

        _routing = true;
        _status = $"Routing to {_destination}…";
        StateHasChanged();

        // Geocode the destination to get lat/lon
        var parts = RoutingDestination.Split(',');
        string street = "", city = "", state = "", zip = "";
        if (parts.Length >= 1) street = parts[0].Trim();
        if (parts.Length >= 2) city = parts[1].Trim();
        if (parts.Length >= 3) state = parts[2].Trim();
        if (parts.Length >= 4) zip = parts[3].Trim();

        var geocodeResult = await Geocoder.GeocodeAsync(street, city, state, zip);

        if (geocodeResult is null)
        {
            _status = "Could not geocode destination address.";
            _routing = false;
            return;
        }

        var destLat = geocodeResult.Latitude;
        var destLon = geocodeResult.Longitude;

        // Place destination marker
        await JS.InvokeVoidAsync("navMapSetDestination", destLat, destLon, _destination);

        // Get current position for origin
        var originLat = GeolocationService.CurrentLatitude;
        var originLon = GeolocationService.CurrentLongitude;

        if (originLat == 0 && originLon == 0)
        {
            _status = $"Destination set. Waiting for GPS fix to draw route…";
            _routing = false;
            return;
        }

        // Fetch route from OSRM (free, no API key)
        try
        {
            var osrmUrl = $"https://router.project-osrm.org/route/v1/driving/{originLon},{originLat};{destLon},{destLat}?overview=full&geometries=geojson";
            using var http = new HttpClient();
            var response = await http.GetAsync(osrmUrl);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<OsrmResponse>();
                if (json?.Routes?.Length > 0)
                {
                    var coords = json.Routes[0].Geometry.Coordinates;
                    // OSRM returns [lon, lat] — Leaflet wants [lat, lon]
                    var latLngs = coords.Select(c => new double[] { c[1], c[0] }).ToArray();
                    await JS.InvokeVoidAsync("navMapDrawRoute", (object)latLngs);

                    var distMiles = json.Routes[0].Distance / 1609.34;
                    var durMin = json.Routes[0].Duration / 60.0;
                    _status = $"{_destination} — {distMiles:F1} mi, {durMin:F0} min";
                }
                else
                {
                    _status = "No route found.";
                }
            }
            else
            {
                _status = "Routing service unavailable.";
            }
        }
        catch (Exception ex)
        {
            _status = $"Routing error: {ex.Message}";
        }

        _routing = false;
    }

    private async Task OpenInGoogleMaps()
    {
        if (string.IsNullOrWhiteSpace(RoutingDestination)) return;
        var dest = Uri.EscapeDataString(RoutingDestination);
        var url = $"https://www.google.com/maps/dir/?api=1&destination={dest}&travelmode=driving";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    public async ValueTask DisposeAsync()
    {
        GeolocationService.OnPositionChanged -= HandlePositionChanged;
        try { await JS.InvokeVoidAsync("navMapDestroy"); } catch { }
    }

    // OSRM response models
    private class OsrmResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("routes")]
        public OsrmRoute[] Routes { get; set; } = Array.Empty<OsrmRoute>();
    }

    private class OsrmRoute
    {
        [System.Text.Json.Serialization.JsonPropertyName("distance")]
        public double Distance { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("duration")]
        public double Duration { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("geometry")]
        public OsrmGeometry Geometry { get; set; } = new();
    }

    private class OsrmGeometry
    {
        [System.Text.Json.Serialization.JsonPropertyName("coordinates")]
        public double[][] Coordinates { get; set; } = Array.Empty<double[]>();
    }
}
