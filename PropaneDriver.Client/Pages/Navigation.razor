@page "/navigation"
@using PropaneDriver.Client.Services
@inject GeolocationService GeolocationService
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

@code {
    [SupplyParameterFromQuery(Name = "destination")]
    public string? DestinationQuery { get; set; }
}

<PageTitle>Navigation</PageTitle>

<div class="nav-page">
    <div class="nav-header">
        <button class="btn-back" @onclick="BackToDeliveries" title="Back to Deliveries">
            &larr; Deliveries
        </button>
        <input type="text" class="form-control destination-input" placeholder="Destination address"
               value="@_destination" @oninput="OnDestinationInput" />
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="nav-status">@_status</div>
    }

    <div class="nav-map">
        <div id="google-map"></div>
        <button class="center-btn" @onclick="CenterOnLocation" title="Center on my location">&#8982;</button>
    </div>
</div>

@code {
    private const double DefaultLat = 47.4273;
    private const double DefaultLon = -92.9378;

    private string _destination = string.Empty;
    private string _fullDestination = string.Empty;
    private string? _status;
    private bool _mapInitialized;
    private bool _routing;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the Google Maps map (lazy-loads the JS API via our
            // server endpoint on first call).
            var lat = GeolocationService.CurrentLatitude;
            var lon = GeolocationService.CurrentLongitude;
            if (lat == 0 && lon == 0) { lat = DefaultLat; lon = DefaultLon; }

            await JS.InvokeVoidAsync("navMapInit", "google-map", lat, lon, 13);
            _mapInitialized = true;

            // Subscribe to GPS updates
            GeolocationService.OnPositionChanged += HandlePositionChanged;

            if (!GeolocationService.IsWatching)
            {
                await GeolocationService.StartWatchingAsync();
            }

            // If arrived with a destination query, auto-route
            if (!string.IsNullOrWhiteSpace(DestinationQuery))
            {
                _fullDestination = DestinationQuery;
                var firstComma = DestinationQuery.IndexOf(',');
                _destination = firstComma > 0 ? DestinationQuery[..firstComma].Trim() : DestinationQuery;
                StateHasChanged();
                await FetchAndDrawRoute();
            }
        }
    }

    private async Task CenterOnLocation()
    {
        if (!_mapInitialized) return;
        try { await JS.InvokeVoidAsync("navMapCenterOnDriver"); } catch { }
    }

    private void BackToDeliveries()
    {
        Nav.NavigateTo("/deliveries");
    }

    private async void HandlePositionChanged(double lat, double lon, double accuracy)
    {
        if (!_mapInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("navMapUpdateDriver", lat, lon);
        }
        catch { }
    }

    private void OnDestinationInput(ChangeEventArgs e)
    {
        _destination = e.Value?.ToString() ?? string.Empty;
        _fullDestination = string.Empty;
    }

    private string RoutingDestination =>
        !string.IsNullOrWhiteSpace(_fullDestination) ? _fullDestination : _destination;

    private async Task FetchAndDrawRoute()
    {
        if (string.IsNullOrWhiteSpace(RoutingDestination)) return;

        // Don't show a transient "routing…" message — the button's disabled
        // state is enough visual feedback, and the real status (distance + ETA,
        // or an error) lands as soon as Google responds.
        _routing = true;
        StateHasChanged();

        // Origin = current GPS position.
        var originLat = GeolocationService.CurrentLatitude;
        var originLon = GeolocationService.CurrentLongitude;

        if (originLat == 0 && originLon == 0)
        {
            _status = "Waiting for GPS fix to draw route…";
            _routing = false;
            return;
        }

        try
        {
            // Google's DirectionsService geocodes the destination address
            // internally, so we pass the raw address string instead of
            // doing a separate geocode call.
            var result = await JS.InvokeAsync<NavRouteResult>(
                "navMapDrawRoute", originLat, originLon, RoutingDestination);

            var distMiles = result.DistanceMeters / 1609.34;
            var durMin = result.DurationSeconds / 60.0;
            _status = $"{_destination} — {distMiles:F1} mi, {durMin:F0} min";
        }
        catch (Exception ex)
        {
            _status = $"Routing error: {ex.Message}";
        }

        _routing = false;
    }

    private class NavRouteResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("distanceMeters")]
        public double DistanceMeters { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("durationSeconds")]
        public double DurationSeconds { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("destinationAddress")]
        public string DestinationAddress { get; set; } = string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        GeolocationService.OnPositionChanged -= HandlePositionChanged;
        try { await JS.InvokeVoidAsync("navMapDestroy"); } catch { }
    }
}
