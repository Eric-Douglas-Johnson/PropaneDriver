@page "/navigation"
@using PropaneDriver.Client.Services
@inject GeolocationService GeolocationService
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS
@inject AddressApiService AddressApi
@inject SpeechService SpeechService
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

@code {
    [SupplyParameterFromQuery(Name = "destination")]
    public string? DestinationQuery { get; set; }

    // Passed from Route.razor so we can display the tank-location note
    // and PUT edits back to the right row. Both are optional — the page
    // still works for ad-hoc typed destinations that have no DB row.
    [SupplyParameterFromQuery(Name = "addressId")]
    public string? AddressIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "tankLocation")]
    public string? TankLocationQuery { get; set; }

    [SupplyParameterFromQuery(Name = "backIn")]
    public bool BackInQuery { get; set; }
}

<PageTitle>Navigation</PageTitle>

<div class="nav-page">
    <div class="nav-header">
        <input type="text" class="form-control destination-input" placeholder="Destination address"
               value="@_destination" @oninput="OnDestinationInput" />

        @if (_addressId != Guid.Empty)
        {
            <div class="addr-meta">
                @if (_backIn)
                {
                    <span class="back-in-badge" title="Back the truck into this driveway">
                        <span class="back-in-icon">&#x21A9;</span>
                        <span class="back-in-text">Back In</span>
                    </span>
                }
                <div class="tank-location">
                @if (_addingTankLocation)
                {
                    <input type="text" class="tank-location-input"
                           name="tank-location-note"
                           autocomplete="off"
                           value="@_tankLocationDraft"
                           @oninput="e => _tankLocationDraft = e.Value?.ToString() ?? string.Empty"
                           placeholder="e.g. behind garage, left of AC" />
                    <button class="btn-mic @(_dictatingTankLocation ? "btn-mic-active" : "")"
                            @onclick="DictateTankLocation" disabled="@_dictatingTankLocation"
                            title="Dictate">&#x1F399;</button>
                    <button class="btn-tank-action btn-tank-save" @onclick="SaveTankLocation"
                            disabled="@(_savingTankLocation || string.IsNullOrWhiteSpace(_tankLocationDraft))">
                        @(_savingTankLocation ? "Saving…" : "Save")
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_tankLocation))
                    {
                        <button class="btn-tank-action btn-tank-clear" @onclick="ClearTankLocation"
                                disabled="@_savingTankLocation">Clear</button>
                    }
                    <button class="btn-tank-action btn-tank-cancel" @onclick="CancelAddTankLocation">Cancel</button>
                }
                else if (!string.IsNullOrWhiteSpace(_tankLocation))
                {
                    <span class="tank-location-label">Tank Location:</span>
                    <span class="tank-location-value">@_tankLocation</span>
                    <button class="btn-tank-edit" @onclick="BeginEditTankLocation" title="Edit tank location">&#x270E;</button>
                }
                else
                {
                    <button class="btn-tank-add" @onclick="BeginEditTankLocation">
                        Add tank location
                    </button>
                }
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="nav-status">@_status</div>
    }

    <div class="nav-map">
        <div id="google-map"></div>
        <button class="btn-back" @onclick="BackToDeliveries" title="Back to Deliveries">
            &larr; Deliveries
        </button>
        <button class="center-btn" @onclick="CenterOnLocation" title="Center on my location">&#8982;</button>
    </div>
</div>

@code {
    private const double DefaultLat = 47.4273;
    private const double DefaultLon = -92.9378;

    private string _destination = string.Empty;
    private string _fullDestination = string.Empty;
    private string? _status;
    private bool _mapInitialized;
    private bool _routing;

    // Tank-location state. _addressId = Guid.Empty means "this
    // destination wasn't launched from a delivery row" (e.g. ad-hoc
    // typed into the address bar), in which case we don't render the
    // line at all — there's no Address row to save against.
    private Guid _addressId = Guid.Empty;
    private string? _tankLocation;
    private bool _savingTankLocation;
    private bool _addingTankLocation;
    private string _tankLocationDraft = string.Empty;
    private bool _dictatingTankLocation;
    private bool _backIn;

    protected override void OnInitialized()
    {
        // Parse query-string state once on page init. These don't change
        // during the page's lifetime — a new address means a fresh nav
        // to /navigation from the Deliveries page.
        if (!string.IsNullOrWhiteSpace(AddressIdQuery)
            && Guid.TryParse(AddressIdQuery, out var parsed))
        {
            _addressId = parsed;
        }

        _tankLocation = string.IsNullOrWhiteSpace(TankLocationQuery)
            ? null
            : TankLocationQuery;

        _backIn = BackInQuery;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the Google Maps map (lazy-loads the JS API via our
            // server endpoint on first call).
            var lat = GeolocationService.CurrentLatitude;
            var lon = GeolocationService.CurrentLongitude;
            if (lat == 0 && lon == 0) { lat = DefaultLat; lon = DefaultLon; }

            await JS.InvokeVoidAsync("navMapInit", "google-map", lat, lon, 13);
            _mapInitialized = true;

            // Subscribe to GPS updates
            GeolocationService.OnPositionChanged += HandlePositionChanged;

            if (!GeolocationService.IsWatching)
            {
                await GeolocationService.StartWatchingAsync();
            }

            // If arrived with a destination query, auto-route
            if (!string.IsNullOrWhiteSpace(DestinationQuery))
            {
                _fullDestination = DestinationQuery;
                var firstComma = DestinationQuery.IndexOf(',');
                _destination = firstComma > 0 ? DestinationQuery[..firstComma].Trim() : DestinationQuery;
                StateHasChanged();
                await FetchAndDrawRoute();
            }
        }
    }

    private async Task CenterOnLocation()
    {
        if (!_mapInitialized) return;
        try { await JS.InvokeVoidAsync("navMapCenterOnDriver"); } catch { }
    }

    private void BackToDeliveries()
    {
        Nav.NavigateTo("/deliveries");
    }

    private void BeginEditTankLocation()
    {
        // Pre-fill the editor with the existing value so the driver can fix
        // a typo or wrong note instead of having to retype from scratch. Also
        // covers the "wrong autofilled address" case: pencil → see what's
        // there → either edit it or hit Clear.
        _tankLocationDraft = _tankLocation ?? string.Empty;
        _addingTankLocation = true;
    }

    private void CancelAddTankLocation()
    {
        _addingTankLocation = false;
        _tankLocationDraft = string.Empty;
    }

    private async Task ClearTankLocation()
    {
        if (_addressId == Guid.Empty || _savingTankLocation) return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Remove the tank location note for this address?");
        if (!confirmed) return;

        _savingTankLocation = true;
        StateHasChanged();

        var ok = await AddressApi.UpdateTankLocationAsync(_addressId, null);

        if (ok)
        {
            _tankLocation = null;
            _addingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _status = "Failed to clear tank location. Please try again.";
        }

        _savingTankLocation = false;
        StateHasChanged();
    }

    private async Task DictateTankLocation()
    {
        _dictatingTankLocation = true;
        StateHasChanged();

        var text = await SpeechService.DictateAsync();
        if (!string.IsNullOrEmpty(text))
            _tankLocationDraft = text;

        _dictatingTankLocation = false;
        StateHasChanged();
    }

    private async Task SaveTankLocation()
    {
        if (_addressId == Guid.Empty || string.IsNullOrWhiteSpace(_tankLocationDraft) || _savingTankLocation) return;

        _savingTankLocation = true;
        StateHasChanged();

        var ok = await AddressApi.UpdateTankLocationAsync(_addressId, _tankLocationDraft.Trim());

        if (ok)
        {
            _tankLocation = _tankLocationDraft.Trim();
            _addingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _status = "Failed to save tank location. Please try again.";
        }

        _savingTankLocation = false;
        StateHasChanged();
    }

    private async void HandlePositionChanged(double lat, double lon, double accuracy)
    {
        if (!_mapInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("navMapUpdateDriver", lat, lon);
        }
        catch { }
    }

    private void OnDestinationInput(ChangeEventArgs e)
    {
        _destination = e.Value?.ToString() ?? string.Empty;
        _fullDestination = string.Empty;
    }

    private string RoutingDestination =>
        !string.IsNullOrWhiteSpace(_fullDestination) ? _fullDestination : _destination;

    private async Task FetchAndDrawRoute()
    {
        if (string.IsNullOrWhiteSpace(RoutingDestination)) return;

        // Don't show a transient "routing…" message — the button's disabled
        // state is enough visual feedback, and the real status (distance + ETA,
        // or an error) lands as soon as Google responds.
        _routing = true;
        StateHasChanged();

        // Origin = current GPS position.
        var originLat = GeolocationService.CurrentLatitude;
        var originLon = GeolocationService.CurrentLongitude;

        if (originLat == 0 && originLon == 0)
        {
            _status = "Waiting for GPS fix to draw route…";
            _routing = false;
            return;
        }

        try
        {
            // Google's DirectionsService geocodes the destination address
            // internally, so we pass the raw address string instead of
            // doing a separate geocode call.
            var result = await JS.InvokeAsync<NavRouteResult>(
                "navMapDrawRoute", originLat, originLon, RoutingDestination);

            var distMiles = result.DistanceMeters / 1609.34;
            var durMin = result.DurationSeconds / 60.0;
            _status = $"{_destination} — {distMiles:F1} mi, {durMin:F0} min";
        }
        catch (Exception ex)
        {
            _status = $"Routing error: {ex.Message}";
        }

        _routing = false;
    }

    private class NavRouteResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("distanceMeters")]
        public double DistanceMeters { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("durationSeconds")]
        public double DurationSeconds { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("destinationAddress")]
        public string DestinationAddress { get; set; } = string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        GeolocationService.OnPositionChanged -= HandlePositionChanged;
        try { await JS.InvokeVoidAsync("navMapDestroy"); } catch { }
    }
}
