@page "/navigation"
@using System.Net.Http.Json
@using PropaneDriver.Client.Services
@using PropaneDriver.Shared.Dtos
@inject GeolocationService GeolocationService
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS
@inject AddressApiService AddressApi
@inject SpeechService SpeechService
@inject HttpClient Http
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

@code {
    [SupplyParameterFromQuery(Name = "destination")]
    public string? DestinationQuery { get; set; }

    // Passed from Route.razor so we can display the tank-location note
    // and PUT edits back to the right row. Both are optional — the page
    // still works for ad-hoc typed destinations that have no DB row.
    [SupplyParameterFromQuery(Name = "addressId")]
    public string? AddressIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "tankLocation")]
    public string? TankLocationQuery { get; set; }

    [SupplyParameterFromQuery(Name = "backIn")]
    public bool BackInQuery { get; set; }

    // The address's stored pin, when it has one. Routing prefers these over
    // the destination string; see FetchAndDrawRoute.
    [SupplyParameterFromQuery(Name = "destinationLat")]
    public double? DestinationLatQuery { get; set; }

    [SupplyParameterFromQuery(Name = "destinationLon")]
    public double? DestinationLonQuery { get; set; }

    // Optional: if launched from a specific delivery row, we fetch the
    // alerts attached to that delivery so they can be shown at the top
    // of the nav page. Empty/missing means no alerts are loaded.
    [SupplyParameterFromQuery(Name = "deliveryId")]
    public string? DeliveryIdQuery { get; set; }
}

<PageTitle>Navigation</PageTitle>

<div class="nav-page">
    <div class="nav-header">
        <input type="text" class="form-control destination-input" placeholder="Destination address"
               value="@_destination" @oninput="OnDestinationInput" />

        @if (_addressId != Guid.Empty)
        {
            <div class="addr-meta">
                @if (_backIn)
                {
                    <button class="back-in-badge"
                            @onclick="() => ToggleBackIn(false)"
                            disabled="@_savingBackIn"
                            title="Back In — tap to clear the flag for this address">
                        <img src="icons/back-in.svg" alt="Back In" class="back-in-icon-img" />
                    </button>
                }
                else
                {
                    <button class="btn-back-in-add"
                            @onclick="() => ToggleBackIn(true)"
                            disabled="@_savingBackIn"
                            title="Mark this driveway as requiring the truck to back in">
                        @(_savingBackIn ? "Saving…" : "+ Back In")
                    </button>
                }
                <div class="tank-location">
                @if (_addingTankLocation)
                {
                    <input type="text" class="tank-location-input"
                           name="tank-location-note"
                           autocomplete="off"
                           value="@_tankLocationDraft"
                           @oninput="e => _tankLocationDraft = e.Value?.ToString() ?? string.Empty"
                           placeholder="e.g. behind garage, left of AC" />
                    <button class="btn-mic @(_dictatingTankLocation ? "btn-mic-active" : "")"
                            @onclick="DictateTankLocation" disabled="@_dictatingTankLocation"
                            title="Dictate">&#x1F399;</button>
                    <button class="btn-tank-action btn-tank-save" @onclick="SaveTankLocation"
                            disabled="@(_savingTankLocation || string.IsNullOrWhiteSpace(_tankLocationDraft))">
                        @(_savingTankLocation ? "Saving…" : "Save")
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_tankLocation))
                    {
                        <button class="btn-tank-action btn-tank-clear" @onclick="ClearTankLocation"
                                disabled="@_savingTankLocation">Clear</button>
                    }
                    <button class="btn-tank-action btn-tank-cancel" @onclick="CancelAddTankLocation">Cancel</button>
                }
                else if (!string.IsNullOrWhiteSpace(_tankLocation))
                {
                    <span class="tank-location-label">Tank Location:</span>
                    <span class="tank-location-value">@_tankLocation</span>
                    <button class="btn-tank-edit" @onclick="BeginEditTankLocation" title="Edit tank location">&#x270E;</button>
                }
                else
                {
                    <button class="btn-tank-add" @onclick="BeginEditTankLocation">
                        Add tank location
                    </button>
                }
                </div>
            </div>
            @if (_alerts.Count > 0)
            {
                <div class="nav-alerts">
                    @foreach (var a in _alerts)
                    {
                        <span class="nav-alert">@a.Message</span>
                    }
                </div>
            }
        }
    </div>

    @if (_progress is not null && _progress.NextManeuver is not null)
    {
        <div class="turn-banner">
            <span class="turn-glyph">@ManeuverGlyph(_progress.NextManeuver.Maneuver)</span>
            <div class="turn-text">
                <span class="turn-distance">in @FormatDistance(_progress.MetersToNextManeuver)</span>
                <span class="turn-instruction">@_progress.NextManeuver.Instruction</span>
            </div>
        </div>
    }
    else if (_progress is not null && _progress.IsFinalApproach)
    {
        <div class="turn-banner turn-banner-arrived">
            <span class="turn-glyph">◎</span>
            <div class="turn-text">
                <span class="turn-distance">in @FormatDistance(_progress.MetersToNextManeuver)</span>
                <span class="turn-instruction">Arriving at destination</span>
            </div>
        </div>
    }
    else if (_progress is not null && _progress.HasArrived)
    {
        <div class="turn-banner turn-banner-arrived">
            <span class="turn-glyph">◎</span>
            <div class="turn-text">
                <span class="turn-instruction">Arrived</span>
            </div>
        </div>
    }

    @* Errors only — routing failures, a missing GPS fix, a save that didn't
       take. Nothing renders here in normal operation. *@
    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="nav-status">@_status</div>
    }

    <div class="nav-map">
        <div id="google-map"></div>
        <button class="btn-back" @onclick="BackToDeliveries" title="Back to Deliveries">
            &larr; Deliveries
        </button>
        <button class="btn-route" @onclick="FetchAndDrawRoute"
                disabled="@(_isRouting || string.IsNullOrWhiteSpace(RoutingDestination))"
                title="Redraw the route to the destination above from your current position">
            @(_isRouting ? "Routing…" : "Refresh Route")
        </button>
        <button class="center-btn" @onclick="CenterOnLocation" title="Center on my location">&#8982;</button>
    </div>
</div>

@code {
    private const double DefaultLat = 47.4273;
    private const double DefaultLon = -92.9378;

    private string _destination = string.Empty;
    private string _fullDestination = string.Empty;

    // The destination's stored pin. Null when the address has none, or when
    // the driver has typed over the destination — at that point the pin
    // belongs to a different place than the text on screen.
    private double? _destinationLatitude;
    private double? _destinationLongitude;
    private string? _status;
    private bool _mapInitialized;

    // True while a Directions request is outstanding. Gates the Refresh Route
    // button so repeated taps don't each bill a request.
    private bool _isRouting;

    // Tank-location state. _addressId = Guid.Empty means "this
    // destination wasn't launched from a delivery row" (e.g. ad-hoc
    // typed into the address bar), in which case we don't render the
    // line at all — there's no Address row to save against.
    private Guid _addressId = Guid.Empty;
    private string? _tankLocation;
    private bool _savingTankLocation;
    private bool _addingTankLocation;
    private string _tankLocationDraft = string.Empty;
    private bool _dictatingTankLocation;
    private bool _backIn;
    private bool _savingBackIn;

    private List<AlertDto> _alerts = new();

    // Turn-by-turn state. The tracker holds the drawn route's maneuver list and
    // decides which one the driver is working on; _progress is the last snapshot
    // it produced and is what the banner renders. Null until a route is drawn,
    // which is also how the banner knows to stay hidden for an ad-hoc typed
    // destination that was never routed.
    private readonly RouteProgressTracker _routeProgressTracker = new();
    private RouteProgressSnapshot? _progress;

    // Last rendered banner text. GPS fixes arrive about once a second; re-rendering
    // on every one churns the whole page for a string that usually hasn't changed,
    // so we only call StateHasChanged when the driver-visible text actually differs.
    private string _lastRenderedBannerText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Parse query-string state first so the initial render has
        // values immediately — these are passed in by Route.razor when
        // launching navigation, used as a fast cache before the server
        // refetch lands.
        if (!string.IsNullOrWhiteSpace(AddressIdQuery)
            && Guid.TryParse(AddressIdQuery, out var parsed))
        {
            _addressId = parsed;
        }

        _tankLocation = string.IsNullOrWhiteSpace(TankLocationQuery)
            ? null
            : TankLocationQuery;

        _backIn = BackInQuery;

        if (DestinationLatQuery is { } queryLatitude && DestinationLonQuery is { } queryLongitude
            && (queryLatitude != 0 || queryLongitude != 0))
        {
            _destinationLatitude = queryLatitude;
            _destinationLongitude = queryLongitude;
        }

        // Refetch canonical address state from the server so the UI
        // reflects flags toggled in other places (Admin page, prior
        // nav session) instead of trusting the URL the page launched
        // from. Silently leaves the query-string cache in place if
        // the fetch fails — better stale than blank.
        if (_addressId != Guid.Empty)
        {
            var fresh = await AddressApi.GetAddressAsync(_addressId);
            if (fresh is not null)
            {
                _tankLocation = string.IsNullOrWhiteSpace(fresh.TankLocation)
                    ? null
                    : fresh.TankLocation;
                _backIn = fresh.BackIn;

                if (fresh.HasCoordinates)
                {
                    _destinationLatitude = fresh.Latitude;
                    _destinationLongitude = fresh.Longitude;
                }
            }
        }

        // Pull any alerts attached to the delivery this nav launched from
        // so the driver sees the same warnings the dispatch page surfaced.
        if (!string.IsNullOrWhiteSpace(DeliveryIdQuery)
            && Guid.TryParse(DeliveryIdQuery, out var deliveryGuid))
        {
            try
            {
                var alerts = await Http.GetFromJsonAsync<List<AlertDto>>(
                    $"api/deliveries/{deliveryGuid}/alerts");
                if (alerts is not null) _alerts = alerts;
            }
            catch
            {
                // Swallow — leaving _alerts empty is the right fallback.
                // A missing alerts strip is less alarming than an error
                // banner on the navigation page.
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the Google Maps map (lazy-loads the JS API via our
            // server endpoint on first call).
            var lat = GeolocationService.CurrentLatitude;
            var lon = GeolocationService.CurrentLongitude;
            if (lat == 0 && lon == 0) { lat = DefaultLat; lon = DefaultLon; }

            await JS.InvokeVoidAsync("navMapInit", "google-map", lat, lon, 13);
            _mapInitialized = true;

            // Subscribe to GPS updates
            GeolocationService.OnPositionChanged += HandlePositionChanged;

            if (!GeolocationService.IsWatching)
            {
                await GeolocationService.StartWatchingAsync();
            }

            // If arrived with a destination query, auto-route
            if (!string.IsNullOrWhiteSpace(DestinationQuery))
            {
                _fullDestination = DestinationQuery;
                var firstComma = DestinationQuery.IndexOf(',');
                _destination = firstComma > 0 ? DestinationQuery[..firstComma].Trim() : DestinationQuery;
                StateHasChanged();
                await FetchAndDrawRoute();
            }
        }
    }

    private async Task CenterOnLocation()
    {
        if (!_mapInitialized) return;
        try { await JS.InvokeVoidAsync("navMapCenterOnDriver"); } catch { }
    }

    private void BackToDeliveries()
    {
        Nav.NavigateTo("/deliveries");
    }

    private void BeginEditTankLocation()
    {
        // Pre-fill the editor with the existing value so the driver can fix
        // a typo or wrong note instead of having to retype from scratch. Also
        // covers the "wrong autofilled address" case: pencil → see what's
        // there → either edit it or hit Clear.
        _tankLocationDraft = _tankLocation ?? string.Empty;
        _addingTankLocation = true;
    }

    private void CancelAddTankLocation()
    {
        _addingTankLocation = false;
        _tankLocationDraft = string.Empty;
    }

    private async Task ClearTankLocation()
    {
        if (_addressId == Guid.Empty || _savingTankLocation) return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Remove the tank location note for this address?");
        if (!confirmed) return;

        _savingTankLocation = true;
        StateHasChanged();

        var ok = await AddressApi.UpdateTankLocationAsync(_addressId, null);

        if (ok)
        {
            _tankLocation = null;
            _addingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _status = "Failed to clear tank location. Please try again.";
        }

        _savingTankLocation = false;
        StateHasChanged();
    }

    private async Task DictateTankLocation()
    {
        _dictatingTankLocation = true;
        StateHasChanged();

        var text = await SpeechService.DictateAsync();
        if (!string.IsNullOrEmpty(text))
            _tankLocationDraft = text;

        _dictatingTankLocation = false;
        StateHasChanged();
    }

    // Flip the BackIn flag on the current address. Used by both the
    // "Back In" badge (tap to clear) and the "+ Back In" button (tap to
    // set). Optimistic-write: we update _backIn first so the UI flips
    // immediately, then revert on failure. The existing _status line
    // surfaces error text.
    private async Task ToggleBackIn(bool newValue)
    {
        if (_addressId == Guid.Empty || _savingBackIn) return;

        _savingBackIn = true;
        StateHasChanged();

        var ok = await AddressApi.UpdateBackInAsync(_addressId, newValue);

        if (ok)
        {
            _backIn = newValue;
        }
        else
        {
            _status = "Failed to update Back In flag. Please try again.";
        }

        _savingBackIn = false;
        StateHasChanged();
    }

    private async Task SaveTankLocation()
    {
        if (_addressId == Guid.Empty || string.IsNullOrWhiteSpace(_tankLocationDraft) || _savingTankLocation) return;

        _savingTankLocation = true;
        StateHasChanged();

        var ok = await AddressApi.UpdateTankLocationAsync(_addressId, _tankLocationDraft.Trim());

        if (ok)
        {
            _tankLocation = _tankLocationDraft.Trim();
            _addingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _status = "Failed to save tank location. Please try again.";
        }

        _savingTankLocation = false;
        StateHasChanged();
    }

    private async void HandlePositionChanged(double lat, double lon, double accuracy)
    {
        if (!_mapInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("navMapUpdateDriver", lat, lon);
        }
        catch { }

        if (!_routeProgressTracker.HasRoute) return;

        _progress = _routeProgressTracker.Update(lat, lon);

        // Only re-render when the text the driver would actually see changes.
        var bannerText = BuildBannerSignature(_progress);
        if (bannerText == _lastRenderedBannerText) return;
        _lastRenderedBannerText = bannerText;

        // This fires off the geolocation callback, not the renderer's
        // synchronization context, so the re-render must be marshalled back
        // with InvokeAsync — a bare StateHasChanged() throws here.
        await InvokeAsync(StateHasChanged);
    }

    // Collapses the snapshot down to exactly what the banner displays, so
    // sub-threshold GPS jitter doesn't trigger a render.
    private static string BuildBannerSignature(RouteProgressSnapshot? progress)
    {
        if (progress is null) return string.Empty;
        if (progress.HasArrived) return "arrived";
        if (!progress.HasGuidance) return string.Empty;

        return string.Concat(
            progress.NextManeuver?.Instruction ?? "final-approach",
            "|", FormatDistance(progress.MetersToNextManeuver));
    }

    private const double MetersPerMile = 1609.34;

    // Under a quarter mile a driver wants feet — "in 300 feet" is actionable
    // where "in 0.1 mi" is not.
    private static string FormatDistance(double meters)
    {
        var miles = meters / MetersPerMile;
        if (miles < 0.25)
        {
            var feet = meters / 0.3048;
            return $"{Math.Round(feet / 50) * 50:F0} ft";
        }
        return $"{miles:F1} mi";
    }

    // Google's maneuver vocabulary grows over time, so anything unrecognized
    // (and the empty maneuver it reports for most first/last steps) falls back
    // to a straight arrow rather than rendering a blank tile.
    private static string ManeuverGlyph(string? maneuver) => maneuver switch
    {
        "turn-left" or "turn-sharp-left" or "turn-slight-left" or "ramp-left"
            or "fork-left" or "keep-left" => "↰",
        "turn-right" or "turn-sharp-right" or "turn-slight-right" or "ramp-right"
            or "fork-right" or "keep-right" => "↱",
        "uturn-left" or "uturn-right" => "↶",
        "roundabout-left" or "roundabout-right" => "↻",
        "merge" => "⇗",
        _ => "↑",
    };

    private void OnDestinationInput(ChangeEventArgs e)
    {
        _destination = e.Value?.ToString() ?? string.Empty;
        _fullDestination = string.Empty;

        // The pin came from the address this page was launched with. Once the
        // driver types a different destination, routing to it would silently
        // ignore what they typed, so drop it and geocode the text instead.
        _destinationLatitude = null;
        _destinationLongitude = null;
    }

    private string RoutingDestination =>
        !string.IsNullOrWhiteSpace(_fullDestination) ? _fullDestination : _destination;

    private async Task FetchAndDrawRoute()
    {
        if (string.IsNullOrWhiteSpace(RoutingDestination)) return;

        // Every call here is a billed Directions request, and on a slow rural
        // connection the driver gets no feedback that one is in flight — so
        // they tap again. Drop taps while one is outstanding rather than
        // firing a request per tap.
        if (_isRouting) return;

        _isRouting = true;
        StateHasChanged();

        try
        {
            // Origin = current GPS position.
            var originLat = GeolocationService.CurrentLatitude;
            var originLon = GeolocationService.CurrentLongitude;

            if (originLat == 0 && originLon == 0)
            {
                _status = "Waiting for GPS fix to draw route…";
                return;
            }

            try
            {
                // Route to the address's stored pin when it has one. Geocoding
                // the address string lands on the road frontage or, for the
                // rural addresses on these routes, on the wrong end of a long
                // driveway; the pin is where the truck actually parks. The
                // address string still goes along as the fallback the JS uses
                // when there's no pin.
                var result = await JS.InvokeAsync<NavRouteResult>(
                    "navMapDrawRoute", originLat, originLon, RoutingDestination,
                    _destinationLatitude, _destinationLongitude);

                // Nothing to report on success: the destination is already in
                // the input above and the banner owns the distance, so a status
                // line here only repeats what's on screen. Clear any error left
                // over from a previous attempt.
                _status = null;

                // Hand the maneuver list to the tracker and prime the banner from
                // the current fix so the first turn shows immediately instead of
                // waiting for the next GPS update to land.
                _routeProgressTracker.SetSteps(result.Steps);
                _progress = _routeProgressTracker.Update(originLat, originLon);
                _lastRenderedBannerText = BuildBannerSignature(_progress);
            }
            catch (Exception ex)
            {
                _status = $"Routing error: {ex.Message}";
                _routeProgressTracker.Clear();
                _progress = null;
                _lastRenderedBannerText = string.Empty;
            }
        }
        finally
        {
            // finally, not a trailing statement: the no-GPS-fix path above
            // returns early, and a throw here would otherwise wedge the button
            // disabled for the rest of the session.
            _isRouting = false;

            // Also required for the OnAfterRenderAsync call path: that lifecycle
            // method does not re-render when it completes, so without this the
            // banner and status line stay blank until something else forces a
            // render.
            StateHasChanged();
        }
    }

    private class NavRouteResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("distanceMeters")]
        public double DistanceMeters { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("durationSeconds")]
        public double DurationSeconds { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("destinationAddress")]
        public string DestinationAddress { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("steps")]
        public List<NavRouteStep> Steps { get; set; } = new();
    }

    public async ValueTask DisposeAsync()
    {
        GeolocationService.OnPositionChanged -= HandlePositionChanged;
        try { await JS.InvokeVoidAsync("navMapDestroy"); } catch { }
    }
}
