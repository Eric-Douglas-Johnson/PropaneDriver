@page "/deliveries"
@using Microsoft.AspNetCore.Components.Authorization
@using PropaneDriver.Client.Authentication
@using PropaneDriver.Client.Services
@using PropaneDriver.Shared.Dtos
@using PropaneDriver.Shared.Interfaces
@inject CustomAuthStateProvider AuthStateProvider
@inject GeolocationService GeolocationService
@inject GeoFenceService GeoFenceService
@inject RouteApiService RouteApi
@inject DeliveryApiService DeliveryApi
@inject DeliveryTimeApiService DeliveryTimeApi
@inject AddressApiService AddressApi
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

<PageTitle>Route</PageTitle>

<!-- Top Button Menu -->
<div class="deliveries-menu">
    <button class="menu-btn" @onclick="ScrollToGpsCheck">View GPS</button>
    <button class="menu-btn" @onclick="NavigateToActive" disabled="@(_activeDelivery is null)">Navigate to Active</button>
    <button class="menu-btn" @onclick="ForceNextDelivery"
            disabled="@(_activeDelivery is null || _forcingNext)"
            title="Mark the current active delivery complete without recording a time, and advance to the next pending stop">
        @(_forcingNext ? "Advancing…" : "Force Next")
    </button>
</div>

<!-- Route Summary -->
<div class="route-summary">
    <div class="summary-section driver-info">
        <h6>Driver</h6>
        <span class="summary-value">@_routeSummary.Driver?.FirstName @_routeSummary.Driver?.LastName</span>
        <span class="summary-detail">@_routeSummary.Driver?.UserName</span>
    </div>
    <div class="summary-section progress-info">
        <h6>Route Progress</h6>
        <span class="summary-value">@_routeSummary.CompletedStops / @_routeSummary.TotalStops stops</span>
        <div class="progress-bar-container">
            <div class="progress-bar-fill" style="width: @(ProgressPercent)%"></div>
        </div>
    </div>
    <div class="summary-section time-info">
        <h6>Est. Completion</h6>
        <span class="summary-value">@_routeSummary.EstimatedCompletionTime</span>
    </div>
    <div class="summary-section alerts-info">
        <h6>Alerts</h6>
        @{
            // Flatten alerts from all deliveries so we can render each
            // AlertDto directly — this lets us track per-alert Seen state
            // and mark it seen on click.
            var allAlerts = _deliveries
                .SelectMany(d => d.Alerts.Select(a => (Customer: d.CustomerName, Alert: a, IsActive: _activeDelivery?.Id == d.Id)))
                .ToList();
        }
        @if (allAlerts.Count == 0)
        {
            <span class="alert-badge alert-ok">No alerts</span>
        }
        else
        {
            @foreach (var entry in allAlerts)
            {
                var captured = entry.Alert;
                <span class="alert-badge alert-warning @(captured.Seen ? "alert-seen" : entry.IsActive ? "alert-flashing" : "alert-static")"
                      @onclick="() => MarkAlertSeen(captured)">
                    @entry.Customer: @entry.Alert.Message
                </span>
            }
        }
    </div>
</div>

<!-- Main Content: Delivery List + Detail -->
<div class="route-content">
    <!-- Delivery List (Left) -->
    <div class="delivery-list">
        <h5>Deliveries</h5>
        @if (!string.IsNullOrEmpty(_saveStatus))
        {
            <div class="@(_saveSuccess ? "text-success" : "text-danger") mb-2" style="font-size:0.8rem;">@_saveStatus</div>
        }
        @if (!_loaded)
        {
            <div style="color:#8892b0;font-size:0.85rem;">Loading route…</div>
        }
        else if (!string.IsNullOrEmpty(_loadError))
        {
            <div class="text-danger" style="font-size:0.85rem;">@_loadError</div>
        }
        else if (_deliveries.Count == 0)
        {
            <div style="color:#8892b0;font-size:0.85rem;">No deliveries for today.</div>
        }
        @foreach (var delivery in _deliveries)
        {
            var statusClass = GetStatusClass(delivery.Status);
            var isSelected = _selectedDelivery?.Id == delivery.Id;
            var isActive = _activeDelivery?.Id == delivery.Id;
            if (delivery.Status == 2)
            {
                // Minimized row for completed deliveries: just the customer
                // name, the Complete tag, and the duration on a single line.
                <div class="delivery-item delivery-item-minimized @statusClass @(isSelected ? "selected" : "")"
                     @onclick="() => SelectDelivery(delivery)">
                    <span class="delivery-item-name">@delivery.CustomerName</span>
                    <span class="delivery-status-badge @statusClass">@GetStatusText(delivery.Status)</span>
                    <span class="delivery-time">@FormatCompletedDuration(delivery)</span>
                </div>
            }
            else
            {
                <div class="delivery-item @statusClass @(isSelected ? "selected" : "") @(isActive ? "active" : "")"
                     @onclick="() => SelectDelivery(delivery)">
                    <div class="delivery-item-header">
                        @if (isActive)
                        {
                            var inside = _geoFenceStatus?.IsInsideFence == true;
                            <span class="delivery-status-badge @(inside ? "geofence-inside-badge" : "active-badge")">● @(inside ? "Arrived" : "Active")</span>
                            @if (delivery.Location.LongRunning && GeoFenceService.IsManualTimerRunning)
                            {
                                <span class="delivery-status-badge manual-timer-badge">@FormatTimer(_timerSeconds)</span>
                            }
                        }
                        <span class="delivery-status-badge @statusClass">@GetStatusText(delivery.Status)</span>
                    </div>
                    <div class="delivery-item-name">@delivery.CustomerName</div>
                    <div class="delivery-item-address">@delivery.Location.FullAddress</div>
                </div>
            }
        }
    </div>

    <!-- Delivery Detail (Right) -->
    <div class="delivery-detail">
        @if (_selectedDelivery is null)
        {
            <div class="no-selection">
                <p>Select a delivery from the list to view details.</p>
            </div>
        }
        else
        {
            <h5>Delivery Details</h5>
            <div class="detail-card">
                @if (_selectedDelivery.Location.BackIn)
                {
                    <div class="detail-row detail-back-in">
                        <label>Back In</label>
                        <img src="icons/back-in.svg" alt="Back In" class="back-in-icon-img" />
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_selectedDelivery.Location.TankLocation))
                {
                    <div class="detail-row">
                        <label>Tank Location</label>
                        <span>@_selectedDelivery.Location.TankLocation</span>
                    </div>
                }
                <div class="detail-row">
                    <label>Avg Delivery Time</label>
                    <span>@_selectedDelivery.AvgDeliveryTimeMinutes min</span>
                </div>
            </div>
            <div class="detail-actions">
                <button class="btn btn-lg btn-primary" @onclick="NavigateToSelected">Navigate</button>
                <button class="btn btn-lg btn-info"
                        @onclick="SetAddressGpsFromTruck"
                        disabled="@_settingAddressGps"
                        title="Overwrite this address's stored coordinates with the truck's current GPS fix">
                    @(_settingAddressGps ? "Saving…" : "Set GPS Pin")
                </button>
                <button class="btn btn-lg btn-warning"
                        @onclick="BeginAddAlert"
                        disabled="@_addingAlertOpen">
                    Add Alert
                </button>
                <button class="btn btn-lg btn-secondary"
                        @onclick="BeginEditTankLocation"
                        disabled="@(_editingTankLocation || _selectedDelivery.Location.Id == Guid.Empty)"
                        title="@(_selectedDelivery.Location.Id == Guid.Empty ? "No address record linked" : "Add or change the tank-location note")">
                    @(string.IsNullOrWhiteSpace(_selectedDelivery.Location.TankLocation) ? "Set Tank Location" : "Edit Tank Location")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_addressGpsStatus))
            {
                <div class="@(_addressGpsSuccess ? "text-success" : "text-danger") mt-1" style="font-size:0.8rem;">
                    @_addressGpsStatus
                </div>
            }
            @if (_addingAlertOpen)
            {
                <div class="mt-2">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Alert message"
                           value="@_alertDraft"
                           @oninput="e => _alertDraft = e.Value?.ToString() ?? string.Empty"
                           @onkeydown="OnAlertKeyDown" />
                    <div class="d-flex gap-2 mt-1">
                        <button class="btn btn-sm btn-primary"
                                @onclick="SaveAlert"
                                disabled="@(_savingAlert || string.IsNullOrWhiteSpace(_alertDraft))">
                            @(_savingAlert ? "Saving…" : "Save Alert")
                        </button>
                        <button class="btn btn-sm btn-secondary"
                                @onclick="CancelAddAlert"
                                disabled="@_savingAlert">Cancel</button>
                    </div>
                </div>
            }
            @if (!string.IsNullOrEmpty(_alertSaveStatus))
            {
                <div class="@(_alertSaveSuccess ? "text-success" : "text-danger") mt-1" style="font-size:0.8rem;">
                    @_alertSaveStatus
                </div>
            }
            @if (_editingTankLocation)
            {
                <div class="mt-2">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="e.g. behind garage, left of AC"
                           value="@_tankLocationDraft"
                           @oninput="e => _tankLocationDraft = e.Value?.ToString() ?? string.Empty" />
                    <div class="d-flex gap-2 mt-1">
                        <button class="btn btn-sm btn-primary"
                                @onclick="SaveTankLocationNote"
                                disabled="@(_savingTankLocation || string.IsNullOrWhiteSpace(_tankLocationDraft))">
                            @(_savingTankLocation ? "Saving…" : "Save")
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_selectedDelivery.Location.TankLocation))
                        {
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="ClearTankLocationNote"
                                    disabled="@_savingTankLocation">Clear</button>
                        }
                        <button class="btn btn-sm btn-secondary"
                                @onclick="CancelEditTankLocation"
                                disabled="@_savingTankLocation">Cancel</button>
                    </div>
                </div>
            }
            @if (!string.IsNullOrEmpty(_tankLocationStatus))
            {
                <div class="@(_tankLocationSuccess ? "text-success" : "text-danger") mt-1" style="font-size:0.8rem;">
                    @_tankLocationStatus
                </div>
            }
            @if (_selectedDelivery.Location.LongRunning && _activeDelivery?.Id == _selectedDelivery.Id)
            {
                <div class="manual-timer-panel">
                    <div class="manual-timer-display">@FormatTimer(_timerSeconds)</div>
                    <div class="manual-timer-actions">
                        <button class="btn btn-lg btn-success"
                                @onclick="StartManualTimer"
                                disabled="@(GeoFenceService.IsManualTimerRunning || _togglingManualTimer)">
                            Start Timer
                        </button>
                        <button class="btn btn-lg btn-danger"
                                @onclick="StopManualTimer"
                                disabled="@(!GeoFenceService.IsManualTimerRunning || _togglingManualTimer)">
                            Stop Timer
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- GPS Debug -->
<div id="gps-check" class="gps-debug mt-3 p-3" style="background: #1a1a2e; border-radius: 8px; border: 1px solid #2a2a4a;">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="m-0" style="color: #e2e8f0;">GPS Check</h5>
        <button class="btn btn-sm btn-outline-info" @onclick="CheckGpsLocation" disabled="@_gpsChecking">
            @(_gpsChecking ? "Checking..." : "Check Location")
        </button>
    </div>
    <div class="d-flex align-items-center gap-2 mb-2" style="font-size: 0.85rem; color: #cbd5e1;">
        <strong>Geofence radius:</strong>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AdjustFenceRadius(-25)">−25 ft</button>
        <span style="min-width: 4.5rem; text-align: center; font-weight: 600;">@GeoFenceService.FenceRadiusFeet.ToString("F0") ft</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AdjustFenceRadius(25)">+25 ft</button>
    </div>
    @if (_gpsCheckResult is not null)
    {
        <div style="font-size: 0.85rem; color: #cbd5e1;">

            <div><strong>Latitude:</strong> @_gpsCheckResult.Latitude.ToString("F6")</div>
            <div><strong>Longitude:</strong> @_gpsCheckResult.Longitude.ToString("F6")</div>
            <div><strong>Accuracy:</strong> @_gpsCheckResult.Accuracy.ToString("F1") m</div>

            @if (_activeDelivery?.Location.HasCoordinates == true)
            {
                var distance = GeoFenceService.HaversineDistance(
                    _gpsCheckResult.Latitude, _gpsCheckResult.Longitude,
                    _activeDelivery.Location.Latitude, _activeDelivery.Location.Longitude);

                var distanceFt = distance * 3.28084;
                var insideFence = distance <= GeoFenceService.FenceRadiusMeters;

                <div><strong>Distance to @_activeDelivery.CustomerName:</strong> @distance.ToString("F1") m (@distanceFt.ToString("F0") ft)</div>
                <div>
                    <strong>Geofence (@GeoFenceService.FenceRadiusFeet.ToString("F0") ft):</strong>
                    @if (insideFence)
                    {
                        <span style="color: #22c55e; font-weight: 600;">INSIDE</span>
                    }
                    else
                    {
                        <span style="color: #ef4444; font-weight: 600;">OUTSIDE</span>
                    }
                </div>
            }
            else
            {
                <div style="color: #8892b0;">No active delivery with coordinates to check against.</div>
            }
        </div>
    }
    @if (_gpsCheckError is not null)
    {
        <div class="text-danger" style="font-size: 0.85rem;">@_gpsCheckError</div>
    }
</div>

@code {
    private RouteSummaryDto _routeSummary = new();
    private List<IDelivery> _deliveries = [];
    private IDelivery? _selectedDelivery;
    private IDelivery? _activeDelivery;
    private GeoFenceEventArgs? _geoFenceStatus;
    private double _timerSeconds;
    private string? _gpsError;
    private string? _saveStatus;
    private bool _saveSuccess;
    private bool _wasInsideFence;
    private bool _gpsChecking;
    private GpsCheckResult? _gpsCheckResult;
    private string? _gpsCheckError;

    // State for the "Set GPS from Truck" button in delivery details. Lives
    // on the page (not the GeoFenceService) because it's a one-shot user
    // action tied to whichever delivery is currently selected.
    private bool _settingAddressGps;
    private string? _addressGpsStatus;
    private bool _addressGpsSuccess;

    // Inline "Add Alert" editor state for the selected delivery.
    private bool _addingAlertOpen;
    private string _alertDraft = string.Empty;
    private bool _savingAlert;
    private string? _alertSaveStatus;
    private bool _alertSaveSuccess;

    // Inline "Set Tank Location" editor state for the selected delivery.
    private bool _editingTankLocation;
    private string _tankLocationDraft = string.Empty;
    private bool _savingTankLocation;
    private string? _tankLocationStatus;
    private bool _tankLocationSuccess;

    // Disables the "Force Next" button while the status update is in flight
    // so the driver can't double-tap and skip two deliveries by accident.
    private bool _forcingNext;

    // Same idea for the LongRunning manual Start/Stop buttons — protects
    // against a double-tap firing two starts or two stops in quick
    // succession before the service has a chance to flip its state.
    private bool _togglingManualTimer;

    // Per-delivery completion duration in seconds, populated as deliveries
    // finish during this session (geofence flow + Force Next). Drives the
    // duration label on minimized completed rows. Deliveries that were
    // already complete on page load won't have an entry — those rows render
    // without a duration.
    private readonly Dictionary<string, double> _completedTimesSeconds = new();

    private record GpsCheckResult(double Latitude, double Longitude, double Accuracy);

    private string? _loadError;
    private bool _loaded;

    private int ProgressPercent => _routeSummary.TotalStops > 0
        ? (int)((double)_routeSummary.CompletedStops / _routeSummary.TotalStops * 100)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        GeoFenceService.OnFenceStatusChanged += HandleFenceStatusChanged;
        GeoFenceService.OnTimerTick += HandleTimerTick;
        GeoFenceService.OnSaveResult += HandleSaveResult;
        GeoFenceService.OnDeliveryCompleted += HandleDeliveryCompleted;
        GeolocationService.OnError += HandleGpsError;

        await LoadTodayRouteAsync();

        // Set the initial active delivery (used by the geofence)
        await SetActiveDeliveryAsync(FindNextDelivery());

        // Auto-start GPS monitoring
        await GeolocationService.StartWatchingAsync();
    }

    private async Task LoadTodayRouteAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var driverId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        var firstName = user.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value;
        var lastName = user.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value;
        var userName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;

        if (string.IsNullOrWhiteSpace(driverId))
        {
            _loadError = "No authenticated driver.";
            _loaded = true;
            return;
        }

        var route = await RouteApi.GetTodayRouteAsync(driverId);

        var driver = new DriverDto
        {
            Id = driverId,
            UserName = userName ?? string.Empty,
            FirstName = firstName ?? string.Empty,
            LastName = lastName ?? string.Empty,
            Role = "driver"
        };

        if (route is null)
        {
            _deliveries = [];
            _routeSummary = new RouteSummaryDto
            {
                Date = DateOnly.FromDateTime(DateTime.Today),
                Driver = driver,
                TotalStops = 0,
                CompletedStops = 0,
                EstimatedCompletionTime = "",
                Alerts = new List<string> { "No route assigned for today." }
            };
        }
        else
        {
            _deliveries = route.Deliveries;
            _routeSummary = new RouteSummaryDto
            {
                Date = route.Date,
                Driver = driver,
                TotalStops = _deliveries.Count,
                CompletedStops = _deliveries.Count(d => d.Status == 2),
                // Server-side GPSHelperService stores expected route duration in
                // minutes on the RouteDbRecord. Project it forward from "now" so
                // the "Est. Completion" tile shows a clock time the driver can
                // actually plan against (e.g. "3:47 PM") rather than a raw
                // duration. If the server didn't compute one (missing GPS on
                // every stop, for instance), leave it blank.
                EstimatedCompletionTime = route.EstimatedRouteTime > 0
                    ? FormatHours(route.EstimatedRouteTime)
                    : string.Empty,
                // The UI renders alerts directly from _deliveries so that
                // per-alert Seen state can be tracked and clicked; the
                // RouteSummaryDto.Alerts string list is no longer used for
                // this page's Alerts section.
                Alerts = new List<string>()
            };
        }

        _selectedDelivery = FindNextDelivery() ?? _deliveries.FirstOrDefault();
        _loaded = true;
    }

    private void AdjustFenceRadius(double deltaFeet)
    {
        GeoFenceService.AdjustFenceRadiusFeet(deltaFeet);
    }

    private async Task ScrollToGpsCheck()
    {
        await JS.InvokeVoidAsync("scrollToElement", "gps-check");
    }

    private void NavigateToActive()
    {
        if (_activeDelivery is null) return;
        OpenGoogleMapsDirections(_activeDelivery);
    }

    // "Force Next" — manually mark the current active delivery as Complete
    // and advance the active pointer to the next pending stop. Use case:
    // the geofence didn't trip (GPS pin off, radius too tight, driver parked
    // far from the tank, etc.) but the delivery is actually done and the
    // driver needs to move on. The driver enters the actual delivery time
    // in minutes so we can still persist a DeliveryTime row for the
    // address-average stats — otherwise force-skipping would quietly skew
    // the route-time estimates toward 0 for repeat stops.
    //
    // The input itself doubles as the confirmation: a valid number means
    // proceed, Cancel or blank means abort.
    private async Task ForceNextDelivery()
    {
        if (_activeDelivery is null || _forcingNext) return;

        var current = _activeDelivery;
        var nextCandidate = _deliveries
            .Where(d => d.Status == 0 && d.Id != current.Id)
            .FirstOrDefault();

        var promptText =
            $"Force-advance past {current.CustomerName}?\n\n" +
            $"Current active: {current.CustomerName}\n" +
            (nextCandidate is not null
                ? $"Will advance to: {nextCandidate.CustomerName}\n\n"
                : "No more pending deliveries after this — active marker will be cleared.\n\n") +
            "Enter the delivery time in MINUTES (e.g. 12 or 7.5).\n" +
            "Cancel or leave blank to abort.";

        // window.prompt returns the typed string, or null on Cancel.
        var raw = await JS.InvokeAsync<string?>("prompt", promptText, "");
        if (string.IsNullOrWhiteSpace(raw)) return; // cancel or empty => abort

        if (!double.TryParse(raw.Trim(), System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var minutes)
            || minutes <= 0
            || double.IsNaN(minutes) || double.IsInfinity(minutes))
        {
            _saveStatus = $"✗ Invalid delivery time '{raw}'. Must be a positive number of minutes.";
            _saveSuccess = false;
            StateHasChanged();
            return;
        }

        if (current.Location.Id == Guid.Empty)
        {
            _saveStatus = $"✗ {current.CustomerName} has no linked address — cannot record a delivery time.";
            _saveSuccess = false;
            StateHasChanged();
            return;
        }

        _forcingNext = true;
        _saveStatus = null;
        StateHasChanged();

        // 1) Save the DeliveryTime row first. If this fails the whole flow
        //    aborts and the delivery stays active, so the driver can retry
        //    without a partial state where status=Complete but no time row
        //    was ever stored.
        var dto = new DeliveryTimeDto
        {
            DeliveryId = current.Id,
            AddressId = current.Location.Id,
            TimeIntervalSeconds = minutes * 60.0
        };

        var timeResult = await DeliveryTimeApi.SaveDeliveryTimeAsync(dto);
        if (!timeResult.Success)
        {
            _saveStatus = $"✗ Failed to save delivery time: {timeResult.ErrorMessage}";
            _saveSuccess = false;
            _forcingNext = false;
            StateHasChanged();
            return;
        }

        // 2) Mark the delivery Complete on the server.
        var ok = await DeliveryApi.UpdateStatusAsync(current.Id, 2);
        if (!ok)
        {
            // Time row saved but status update failed — surface the mismatch
            // so the driver knows the stop isn't fully reconciled. The server
            // logs the HTTP failure via ErrorLogService already.
            _saveStatus = $"✗ Saved time but failed to mark {current.CustomerName} complete — see ErrorLog.";
            _saveSuccess = false;
            _forcingNext = false;
            StateHasChanged();
            return;
        }

        // 3) Sync local state and advance the active pointer. Mirrors
        //    HandleDeliveryCompleted on the normal geofence-driven flow.
        current.Status = 2;
        _completedTimesSeconds[current.Id] = minutes * 60.0;
        _routeSummary.CompletedStops = _deliveries.Count(d => d.Status == 2);

        var next = FindNextDelivery();
        await SetActiveDeliveryAsync(next); // null clears the active marker when route is done

        _saveStatus = $"✓ Saved {minutes:F1} min for {current.CustomerName}"
            + (next is not null ? $" — now active: {next.CustomerName}" : " — no more pending deliveries");
        _saveSuccess = true;
        _forcingNext = false;
        StateHasChanged();
    }

    private void NavigateToSelected()
    {
        if (_selectedDelivery is null) return;
        OpenGoogleMapsDirections(_selectedDelivery);
    }

    private async Task StartManualTimer()
    {
        if (_togglingManualTimer || _activeDelivery is null) return;
        _togglingManualTimer = true;
        try
        {
            await GeoFenceService.StartManualTimerAsync();
        }
        finally
        {
            _togglingManualTimer = false;
        }
    }

    private async Task StopManualTimer()
    {
        if (_togglingManualTimer || !GeoFenceService.IsManualTimerRunning) return;
        _togglingManualTimer = true;
        try
        {
            // The GeoFenceService stops the tick, saves the DeliveryTime,
            // marks the delivery complete, and fires OnDeliveryCompleted —
            // which our HandleDeliveryCompleted already routes through to
            // advance the active pointer and update the completed-times
            // dictionary. Same downstream path the geofence flow takes.
            await GeoFenceService.StopManualTimerAsync();
        }
        finally
        {
            _togglingManualTimer = false;
        }
    }

    private void OpenGoogleMapsDirections(IDelivery delivery)
    {
        var address = delivery.Location.FullAddress;
        if (string.IsNullOrWhiteSpace(address)) return;
        var dest = Uri.EscapeDataString(address);

        // Pass the AddressId + current TankLocation so the Navigation
        // page can show the note below the address without an extra
        // server round-trip, and knows which address to PUT against
        // when the driver taps "Add tank location".
        var qs = $"destination={dest}&addressId={delivery.Location.Id}";
        if (!string.IsNullOrWhiteSpace(delivery.Location.TankLocation))
        {
            qs += $"&tankLocation={Uri.EscapeDataString(delivery.Location.TankLocation)}";
        }
        if (delivery.Location.BackIn)
        {
            qs += "&backIn=true";
        }
        Nav.NavigateTo($"/navigation?{qs}");
    }

    // "Set GPS from Truck" — overwrite the stored coordinates on the
    // selected delivery's Address row with the truck's current GPS fix.
    // Useful when the geocoded pin is off (long rural driveways, the
    // tank is behind the house, etc.). We prompt first so one fat-
    // finger doesn't silently replace a good location with a bad one.
    private async Task SetAddressGpsFromTruck()
    {
        if (_selectedDelivery is null) return;

        var addressId = _selectedDelivery.Location.Id;
        if (addressId == Guid.Empty)
        {
            _addressGpsStatus = "This delivery has no linked address record.";
            _addressGpsSuccess = false;
            return;
        }

        var lat = GeolocationService.CurrentLatitude;
        var lon = GeolocationService.CurrentLongitude;

        if (lat == 0 && lon == 0)
        {
            _addressGpsStatus = "No GPS fix yet — wait for a position update and try again.";
            _addressGpsSuccess = false;
            return;
        }

        // Capture the current stored coordinates so we can show the driver
        // what's about to change. If the address has no saved coords yet
        // (HasCoordinates false), there's no meaningful delta — just show
        // the new pin.
        var oldLat = _selectedDelivery.Location.Latitude;
        var oldLon = _selectedDelivery.Location.Longitude;
        var hadCoords = _selectedDelivery.Location.HasCoordinates;

        // Distance in feet between old and new pin, so the prompt/status
        // lines are actionable ("you're moving the pin 320 ft") rather
        // than asking the driver to eyeball raw lat/lon deltas.
        var moveFeet = hadCoords
            ? GeoFenceService.HaversineDistance(oldLat, oldLon, lat, lon) * 3.28084
            : 0.0;

        // Native browser confirm. Good enough for a driver-on-a-phone UX
        // and avoids pulling in a modal library just for this one prompt.
        var prompt = hadCoords
            ? $"Overwrite stored GPS for {_selectedDelivery.CustomerName}?\n\n" +
              $"Current: ({oldLat:F6}, {oldLon:F6})\n" +
              $"New:     ({lat:F6}, {lon:F6})\n" +
              $"Change:  ~{moveFeet:F0} ft"
            : $"Set GPS for {_selectedDelivery.CustomerName} to ({lat:F6}, {lon:F6})?\n\n" +
              "(No coordinates currently stored.)";

        var confirmed = await JS.InvokeAsync<bool>("confirm", prompt);
        if (!confirmed) return;

        _settingAddressGps = true;
        _addressGpsStatus = null;
        StateHasChanged();

        var ok = await AddressApi.UpdateCoordinatesAsync(addressId, lat, lon);

        if (ok)
        {
            // Update the in-memory delivery so the detail view reflects
            // the new coordinates immediately, without needing a reload.
            _selectedDelivery.Location.Latitude = lat;
            _selectedDelivery.Location.Longitude = lon;
            _addressGpsStatus = hadCoords
                ? $"✓ Saved — pin moved ~{moveFeet:F0} ft to ({lat:F6}, {lon:F6})"
                : $"✓ Saved ({lat:F6}, {lon:F6})";
            _addressGpsSuccess = true;
        }
        else
        {
            _addressGpsStatus = "✗ Failed to save — see ErrorLog.";
            _addressGpsSuccess = false;
        }

        _settingAddressGps = false;
    }

    private void SelectDelivery(IDelivery delivery)
    {
        // Selecting a delivery only changes the detail view; the geofence
        // stays locked to the current/active delivery. Close any open
        // inline editors so a draft for the previous row can't be saved
        // against the newly-selected one.
        _selectedDelivery = delivery;
        _addingAlertOpen = false;
        _alertDraft = string.Empty;
        _alertSaveStatus = null;
        _editingTankLocation = false;
        _tankLocationDraft = string.Empty;
        _tankLocationStatus = null;
    }

    private void BeginAddAlert()
    {
        _alertDraft = string.Empty;
        _alertSaveStatus = null;
        _addingAlertOpen = true;
    }

    private void CancelAddAlert()
    {
        _addingAlertOpen = false;
        _alertDraft = string.Empty;
    }

    private async Task OnAlertKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_savingAlert && !string.IsNullOrWhiteSpace(_alertDraft))
        {
            await SaveAlert();
        }
    }

    private async Task SaveAlert()
    {
        if (_selectedDelivery is null
            || string.IsNullOrWhiteSpace(_alertDraft)
            || _savingAlert) return;

        _savingAlert = true;
        _alertSaveStatus = null;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync(
                $"api/deliveries/{_selectedDelivery.Id}/alerts",
                new CreateAlertDto { Message = _alertDraft.Trim() });

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<AlertDto>();
                if (created is not null)
                {
                    // Append to the in-memory delivery so the route-summary
                    // Alerts strip picks it up on the next render — no need
                    // to reload the route.
                    _selectedDelivery.Alerts.Add(created);
                }
                _alertSaveStatus = "✓ Alert added";
                _alertSaveSuccess = true;
                _addingAlertOpen = false;
                _alertDraft = string.Empty;
            }
            else
            {
                _alertSaveStatus = $"✗ Failed to add alert: {(int)response.StatusCode}";
                _alertSaveSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _alertSaveStatus = $"✗ Error: {ex.Message}";
            _alertSaveSuccess = false;
        }
        finally
        {
            _savingAlert = false;
        }
    }

    private void BeginEditTankLocation()
    {
        if (_selectedDelivery is null) return;
        _tankLocationDraft = _selectedDelivery.Location.TankLocation ?? string.Empty;
        _tankLocationStatus = null;
        _editingTankLocation = true;
    }

    private void CancelEditTankLocation()
    {
        _editingTankLocation = false;
        _tankLocationDraft = string.Empty;
    }

    private async Task SaveTankLocationNote()
    {
        if (_selectedDelivery is null
            || string.IsNullOrWhiteSpace(_tankLocationDraft)
            || _savingTankLocation) return;

        var addressId = _selectedDelivery.Location.Id;
        if (addressId == Guid.Empty)
        {
            _tankLocationStatus = "✗ This delivery has no linked address record.";
            _tankLocationSuccess = false;
            return;
        }

        _savingTankLocation = true;
        _tankLocationStatus = null;
        StateHasChanged();

        var trimmed = _tankLocationDraft.Trim();
        var ok = await AddressApi.UpdateTankLocationAsync(addressId, trimmed);

        if (ok)
        {
            _selectedDelivery.Location.TankLocation = trimmed;
            _tankLocationStatus = "✓ Tank location saved";
            _tankLocationSuccess = true;
            _editingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _tankLocationStatus = "✗ Failed to save — see ErrorLog.";
            _tankLocationSuccess = false;
        }

        _savingTankLocation = false;
    }

    private async Task ClearTankLocationNote()
    {
        if (_selectedDelivery is null || _savingTankLocation) return;
        var addressId = _selectedDelivery.Location.Id;
        if (addressId == Guid.Empty) return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Remove the tank location note for this address?");
        if (!confirmed) return;

        _savingTankLocation = true;
        _tankLocationStatus = null;
        StateHasChanged();

        var ok = await AddressApi.UpdateTankLocationAsync(addressId, null);

        if (ok)
        {
            _selectedDelivery.Location.TankLocation = null;
            _tankLocationStatus = "✓ Tank location cleared";
            _tankLocationSuccess = true;
            _editingTankLocation = false;
            _tankLocationDraft = string.Empty;
        }
        else
        {
            _tankLocationStatus = "✗ Failed to clear — see ErrorLog.";
            _tankLocationSuccess = false;
        }

        _savingTankLocation = false;
    }

    private void HandleSaveResult(PropaneDriver.Client.Services.SaveDeliveryTimeResult result)
    {
        _saveSuccess = result.Success;
        _saveStatus = result.Success
            ? "✓ Delivery time saved"
            : $"✗ Save failed: {result.ErrorMessage}";
        InvokeAsync(StateHasChanged);
    }

    private void HandleFenceStatusChanged(GeoFenceEventArgs args)
    {
        _geoFenceStatus = args;
        _wasInsideFence = args.IsInsideFence;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleDeliveryCompleted(IDelivery completed, double elapsedSeconds)
    {
        // The GeoFenceService has already set completed.Status = 2 and
        // persisted it server-side. We just need to update UI state and
        // advance to the next pending delivery.
        var localMatch = _deliveries.FirstOrDefault(d => d.Id == completed.Id);
        if (localMatch is not null) localMatch.Status = 2;

        _completedTimesSeconds[completed.Id] = elapsedSeconds;

        _routeSummary.CompletedStops = _deliveries.Count(d => d.Status == 2);

        var next = FindNextDelivery();
        if (next is not null && next.Id != completed.Id)
        {
            await SetActiveDeliveryAsync(next);
        }
        else if (next is null)
        {
            await SetActiveDeliveryAsync(null);
        }

        await InvokeAsync(StateHasChanged);
    }

    private IDelivery? FindNextDelivery()
    => _deliveries.FirstOrDefault(d => d.Status == 0);

    private async Task SetActiveDeliveryAsync(IDelivery? delivery)
    {
        _activeDelivery = delivery;
        _geoFenceStatus = null;
        _timerSeconds = 0;
        _wasInsideFence = false;

        // Awaited so that on initial page load, any persisted fence-entry
        // timer is restored before the GPS service starts emitting position
        // updates. A fire-and-forget call would race with the first GPS tick
        // and the timer would restart from zero.
        await GeoFenceService.SetTargetAsync(delivery);

        // Keep the detail view in sync if nothing is selected yet
        if (_selectedDelivery is null && delivery is not null)
        {
            _selectedDelivery = delivery;
        }
    }

    private void HandleTimerTick(double seconds)
    {
        _timerSeconds = seconds;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGpsError(string error)
    {
        _gpsError = error;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatHours(double totalMinutes)
    {
        var ts = TimeSpan.FromMinutes(totalMinutes);
        return ts.Hours > 0
            ? $"{ts.Hours}h {ts.Minutes}m"
            : $"{ts.Minutes}m";
    }

    private string FormatCompletedDuration(IDelivery delivery)
    {
        // Prefer the in-session value (geofence flow + Force Next populate this
        // dictionary as deliveries finish). Fall back to the server-persisted
        // RecordedTimeSeconds so completed rows still show their duration after
        // a page reload — the dictionary is empty on a fresh page instance.
        if (!_completedTimesSeconds.TryGetValue(delivery.Id, out var seconds))
        {
            if (delivery.RecordedTimeSeconds is not { } persisted) return string.Empty;
            seconds = persisted;
        }
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds:D2}s";
    }

    private static string FormatTimer(double totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        return ts.Hours > 0
            ? $"{ts.Hours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    private async Task CheckGpsLocation()
    {
        _gpsChecking = true;
        _gpsCheckResult = null;
        _gpsCheckError = null;

        try
        {
            // Use the current values from the GeolocationService (already watching)
            if (GeolocationService.IsWatching && (GeolocationService.CurrentLatitude != 0 || GeolocationService.CurrentLongitude != 0))
            {
                _gpsCheckResult = new GpsCheckResult(
                    GeolocationService.CurrentLatitude,
                    GeolocationService.CurrentLongitude,
                    GeolocationService.CurrentAccuracy);
            }
            else
            {
                _gpsCheckError = "GPS not available yet. Ensure location permissions are granted.";
            }
        }
        catch (Exception ex)
        {
            _gpsCheckError = $"GPS error: {ex.Message}";
        }
        finally
        {
            _gpsChecking = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        GeoFenceService.OnFenceStatusChanged -= HandleFenceStatusChanged;
        GeoFenceService.OnTimerTick -= HandleTimerTick;
        GeoFenceService.OnSaveResult -= HandleSaveResult;
        GeoFenceService.OnDeliveryCompleted -= HandleDeliveryCompleted;
        GeolocationService.OnError -= HandleGpsError;

        // Do NOT dispose GeolocationService — it is a shared singleton.
        try { await GeolocationService.StopWatchingAsync(); } catch { }
    }

    private async Task MarkAlertSeen(AlertDto alert)
    {
        if (alert.Seen) return;

        // Optimistically mark seen so the badge stops flashing immediately;
        // if the server call fails, roll back.
        alert.Seen = true;
        StateHasChanged();

        try
        {
            var response = await Http.PutAsync($"api/alerts/{alert.Id}/seen", null);
            if (!response.IsSuccessStatusCode)
            {
                alert.Seen = false;
                StateHasChanged();
            }
        }
        catch
        {
            alert.Seen = false;
            StateHasChanged();
        }
    }

    private static string GetStatusClass(int status) => status switch
    {
        0 => "status-pending",
        2 => "status-complete",
        3 => "status-unable",
        _ => ""
    };

    private static string GetStatusText(int status) => status switch
    {
        0 => "Pending",
        2 => "Complete",
        3 => "Unable",
        _ => "Unknown"
    };

}
