@page "/deliveries"
@using Microsoft.AspNetCore.Components.Authorization
@using PropaneDriver.Client.Authentication
@using PropaneDriver.Client.Services
@using PropaneDriver.Shared.Dtos
@inject CustomAuthStateProvider AuthStateProvider
@inject GeolocationService GeolocationService
@inject GeoFenceService GeoFenceService
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

<PageTitle>Route</PageTitle>

<!-- Route Summary -->
<div class="route-summary">
    <div class="summary-section driver-info">
        <h6>Driver</h6>
        <span class="summary-value">@_routeSummary.Driver?.FirstName @_routeSummary.Driver?.LastName</span>
        <span class="summary-detail">Truck @_routeSummary.Driver?.TruckNumber &bull; @_routeSummary.Driver?.LicenseClass</span>
    </div>
    <div class="summary-section progress-info">
        <h6>Route Progress</h6>
        <span class="summary-value">@_routeSummary.CompletedStops / @_routeSummary.TotalStops stops</span>
        <div class="progress-bar-container">
            <div class="progress-bar-fill" style="width: @(ProgressPercent)%"></div>
        </div>
    </div>
    <div class="summary-section time-info">
        <h6>Est. Completion</h6>
        <span class="summary-value">@_routeSummary.EstimatedCompletionTime</span>
        <span class="summary-detail">@_routeSummary.TotalGallonsDelivered gal delivered &bull; @_routeSummary.TotalGallonsRemaining gal remaining</span>
    </div>
    <div class="summary-section alerts-info">
        <h6>Alerts</h6>
        @if (_routeSummary.Alerts.Count == 0)
        {
            <span class="alert-badge alert-ok">No alerts</span>
        }
        else
        {
            @foreach (var alert in _routeSummary.Alerts)
            {
                <span class="alert-badge alert-warning">@alert</span>
            }
        }
    </div>
</div>

<!-- Main Content: Delivery List + Detail -->
<div class="route-content">
    <!-- Delivery List (Left) -->
    <div class="delivery-list">
        <h5>Deliveries</h5>
        @foreach (var delivery in _deliveries)
        {
            var statusClass = GetStatusClass(delivery.Status);
            var isSelected = _selectedDelivery?.Id == delivery.Id;
            <div class="delivery-item @statusClass @(isSelected ? "selected" : "")"
                 @onclick="() => SelectDelivery(delivery)">
                <div class="delivery-item-header">
                    <span class="delivery-time">@delivery.ScheduledTime</span>
                    <span class="delivery-status-badge @statusClass">@GetStatusText(delivery.Status)</span>
                </div>
                <div class="delivery-item-name">@delivery.CustomerName</div>
                <div class="delivery-item-address">@delivery.Location.FullAddress</div>
            </div>
        }
    </div>

    <!-- Delivery Detail (Right) -->
    <div class="delivery-detail">
        @if (_selectedDelivery is null)
        {
            <div class="no-selection">
                <p>Select a delivery from the list to view details.</p>
            </div>
        }
        else
        {
            <h5>Delivery Details</h5>
            <div class="detail-card">
                <div class="detail-row">
                    <label>Customer</label>
                    <span>@_selectedDelivery.CustomerName</span>
                </div>
                <div class="detail-row">
                    <label>Address</label>
                    <span>@_selectedDelivery.Location.FullAddress</span>
                </div>
                @if (_selectedDelivery.Location.HasCoordinates)
                {
                    <div class="detail-row">
                        <label>GPS</label>
                        <span>@_selectedDelivery.Location.Latitude.ToString("F6"), @_selectedDelivery.Location.Longitude.ToString("F6")</span>
                    </div>
                }
                @if (_geoFenceStatus != null)
                {
                    <div class="detail-row">
                        <label>Distance</label>
                        <span>@(_geoFenceStatus.DistanceMeters.ToString("F1")) m (@((_geoFenceStatus.DistanceMeters * 3.28084).ToString("F0")) ft)</span>
                    </div>
                    <div class="detail-row">
                        <label>Geofence</label>
                        @if (_geoFenceStatus.IsInsideFence)
                        {
                            <span class="geofence-badge geofence-inside">⏱ Inside — @FormatTimer(_timerSeconds)</span>
                        }
                        else
                        {
                            <span class="geofence-badge geofence-outside">Outside (100 ft radius)</span>
                        }
                    </div>
                }
                @if (_gpsError != null)
                {
                    <div class="detail-row">
                        <label>GPS Status</label>
                        <span class="text-danger">@_gpsError</span>
                    </div>
                }
                <div class="detail-row">
                    <label>Scheduled Time</label>
                    <span>@_selectedDelivery.ScheduledTime</span>
                </div>
                <div class="detail-row">
                    <label>Avg Delivery Time</label>
                    <span>@_selectedDelivery.AvgDeliveryTimeMinutes min</span>
                </div>
                <div class="detail-row">
                    <label>Tank Size</label>
                    <span>@_selectedDelivery.TankSize gal</span>
                </div>
                <div class="detail-row">
                    <label>Gallons Delivered</label>
                    <span>@_selectedDelivery.GallonsDelivered gal</span>
                </div>
                <div class="detail-row">
                    <label>Status</label>
                    <span class="delivery-status-badge @GetStatusClass(_selectedDelivery.Status)">
                        @GetStatusText(_selectedDelivery.Status)
                    </span>
                </div>
            </div>

            <div class="detail-actions">
                @if (_selectedDelivery.Status == 0)
                {
                    <button class="btn btn-primary" @onclick="() => UpdateStatus(1)">Start Delivery</button>
                }
                else if (_selectedDelivery.Status == 1)
                {
                    <button class="btn btn-success" @onclick="() => UpdateStatus(2)">Mark Complete</button>
                    <button class="btn btn-danger" @onclick="() => UpdateStatus(3)">Mark Unable to Deliver</button>
                }

                @if (!GeolocationService.IsWatching)
                {
                    <button class="btn btn-outline-info mt-2" @onclick="StartGpsMonitoring">📍 Start GPS Monitoring</button>
                }
                else
                {
                    <button class="btn btn-outline-warning mt-2" @onclick="StopGpsMonitoring">⏹ Stop GPS Monitoring</button>
                }
            </div>
        }
    </div>
</div>

@code {
    private RouteSummaryDto _routeSummary = new();
    private List<DeliveryDto> _deliveries = [];
    private DeliveryDto? _selectedDelivery;
    private GeoFenceEventArgs? _geoFenceStatus;
    private double _timerSeconds;
    private string? _gpsError;

    private int ProgressPercent => _routeSummary.TotalStops > 0
        ? (int)((double)_routeSummary.CompletedStops / _routeSummary.TotalStops * 100)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        // TODO: Replace with real API calls
        LoadMockData();

        GeoFenceService.OnFenceStatusChanged += HandleFenceStatusChanged;
        GeoFenceService.OnTimerTick += HandleTimerTick;
        GeolocationService.OnError += HandleGpsError;

        // Set the initial target to the first in-progress or pending delivery
        var nextDelivery = _deliveries.FirstOrDefault(d => d.Status == 1)
            ?? _deliveries.FirstOrDefault(d => d.Status == 0);
        GeoFenceService.SetTarget(nextDelivery);
    }

    private void SelectDelivery(DeliveryDto delivery)
    {
        _selectedDelivery = delivery;
        _geoFenceStatus = null;
        _timerSeconds = 0;

        // Update geofence target when selecting a delivery
        GeoFenceService.SetTarget(delivery);
    }

    private async Task StartGpsMonitoring()
    {
        _gpsError = null;
        await GeolocationService.StartWatchingAsync();
    }

    private async Task StopGpsMonitoring()
    {
        await GeolocationService.StopWatchingAsync();
    }

    private void HandleFenceStatusChanged(GeoFenceEventArgs args)
    {
        _geoFenceStatus = args;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTimerTick(double seconds)
    {
        _timerSeconds = seconds;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGpsError(string error)
    {
        _gpsError = error;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatTimer(double totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        return ts.Hours > 0
            ? $"{ts.Hours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    private void UpdateStatus(int newStatus)
    {
        if (_selectedDelivery is null) return;

        var oldStatus = _selectedDelivery.Status;
        _selectedDelivery.Status = newStatus;

        if (newStatus == 2 && oldStatus != 2)
        {
            _routeSummary.CompletedStops++;
            _routeSummary.TotalGallonsDelivered += _selectedDelivery.GallonsDelivered;
            _routeSummary.TotalGallonsRemaining -= _selectedDelivery.GallonsDelivered;
        }

        // Auto-advance geofence target to next pending/in-progress delivery
        if (newStatus >= 2)
        {
            var nextDelivery = _deliveries.FirstOrDefault(d => d.Status == 1)
                ?? _deliveries.FirstOrDefault(d => d.Status == 0);
            GeoFenceService.SetTarget(nextDelivery);
        }
    }

    public async ValueTask DisposeAsync()
    {
        GeoFenceService.OnFenceStatusChanged -= HandleFenceStatusChanged;
        GeoFenceService.OnTimerTick -= HandleTimerTick;
        GeolocationService.OnError -= HandleGpsError;
        await GeolocationService.DisposeAsync();
    }

    private static string GetStatusClass(int status) => status switch
    {
        0 => "status-pending",
        1 => "status-in-progress",
        2 => "status-complete",
        3 => "status-unable",
        _ => ""
    };

    private static string GetStatusText(int status) => status switch
    {
        0 => "Pending",
        1 => "In Progress",
        2 => "Complete",
        3 => "Unable",
        _ => "Unknown"
    };

