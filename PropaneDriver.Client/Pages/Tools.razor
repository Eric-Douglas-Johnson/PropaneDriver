@page "/tools"
@using PropaneDriver.Shared.Dtos
@using PropaneDriver.Shared.Enums
@inject HttpClient Http
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]

<PageTitle>Tools</PageTitle>

<div class="tools-page">
    <h4 class="tools-title">Tools</h4>

    <div class="tools-card">
        <h5>Document Scanner</h5>
        <p class="tools-hint">
            Pick one or more image files, then press <strong>Scan</strong> to run
            them through Azure Document Intelligence. The raw OCR lines per page
            are shown below.
        </p>

        <div class="admin-row">
            <div class="admin-field" style="max-width: 220px;">
                <label>Model</label>
                <select class="form-select form-select-sm" @bind="_selectedModel" disabled="@_scanning">
                    @foreach (var modelOption in Enum.GetValues<AzureDocumentIntelligenceModel>())
                    {
                        <option value="@modelOption">@modelOption</option>
                    }
                </select>
            </div>
            @if (_selectedModel == AzureDocumentIntelligenceModel.Invoice)
            {
                <div class="admin-field" style="max-width: 220px;">
                    <label>Company invoice type</label>
                    <select class="form-select form-select-sm"
                            @bind="_selectedCompanyInvoiceType"
                            disabled="@_scanning">
                        @foreach (var companyInvoiceTypeOption in Enum.GetValues<CompanyInvoiceType>())
                        {
                            <option value="@companyInvoiceTypeOption">@companyInvoiceTypeOption</option>
                        }
                    </select>
                </div>
            }
            @if (IsHooverScanFlow)
            {
                <div class="admin-field">
                    <label>Equipment image (Read)</label>
                    <input type="file" id="tools-hoover-equipment-file" @key="_hooverEquipmentInputKey"
                           accept="image/*" class="form-control form-control-sm"
                           @onchange="OnHooverEquipmentImageSelected" />
                </div>
                <div class="admin-field">
                    <label>Invoice image (Invoice)</label>
                    <input type="file" id="tools-hoover-invoice-file" @key="_hooverInvoiceInputKey"
                           accept="image/*" class="form-control form-control-sm"
                           @onchange="OnHooverInvoiceImageSelected" />
                </div>
            }
            else
            {
                <div class="admin-field flex-2">
                    <label>Select image file(s)</label>
                    <input type="file" id="tools-document-file" @key="_fileInputKey"
                           accept="image/*" multiple class="form-control form-control-sm"
                           @onchange="OnFileSelected" />
                </div>
            }
        </div>

        @if (IsHooverScanFlow)
        {
            @if (!string.IsNullOrEmpty(_hooverEquipmentImageFileName) || !string.IsNullOrEmpty(_hooverInvoiceImageFileName))
            {
                <div class="tools-selection">
                    <div class="tools-selection-header">
                        Hoover scan — needs both images
                    </div>
                    <ol class="tools-selection-list">
                        <li>
                            <strong>Equipment:</strong>
                            @(string.IsNullOrEmpty(_hooverEquipmentImageFileName) ? "(not selected)" : _hooverEquipmentImageFileName)
                        </li>
                        <li>
                            <strong>Invoice:</strong>
                            @(string.IsNullOrEmpty(_hooverInvoiceImageFileName) ? "(not selected)" : _hooverInvoiceImageFileName)
                        </li>
                    </ol>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary"
                                @onclick="OnHooverScanClicked"
                                disabled="@(_scanning || !HasBothHooverImagesSelected)">
                            @(_scanning ? "Scanning…" : "Scan Hoover invoice")
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="ClearHooverSelection"
                                disabled="@_scanning">
                            Clear selection
                        </button>
                    </div>
                </div>
            }
        }
        else if (_selectedFileNames.Count > 0)
        {
            <div class="tools-selection">
                <div class="tools-selection-header">
                    Selected (@_selectedFileNames.Count) — not scanned yet
                </div>
                <ol class="tools-selection-list">
                    @foreach (var fileName in _selectedFileNames)
                    {
                        <li>@(string.IsNullOrEmpty(fileName) ? "(unnamed)" : fileName)</li>
                    }
                </ol>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-primary"
                            @onclick="OnScanClicked"
                            disabled="@_scanning">
                        @(_scanning
                            ? "Scanning…"
                            : $"Scan {_selectedFileNames.Count} file{(_selectedFileNames.Count == 1 ? "" : "s")}")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="ClearSelection"
                            disabled="@_scanning">
                        Clear selection
                    </button>
                </div>
            </div>
        }

        @if (_scanning)
        {
            <div class="d-flex align-items-center gap-2 mt-2" style="font-size:0.8rem; color:#8892b0;">
                <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                <span>@(_scanProgress ?? "Scanning files…")</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(_scanStatus))
        {
            <div class="@(_scanStatusSuccess ? "text-success" : "text-warning") mt-2"
                 style="font-size:0.8rem;">
                @_scanStatus
            </div>
        }
    </div>

    @if (_scannedDocuments.Count > 0)
    {
        <div class="tools-card">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="m-0">Scanned Documents (@_scannedDocuments.Count)</h5>
                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                        @onclick="ClearScannedDocuments">
                    Clear
                </button>
            </div>

            @foreach (var document in _scannedDocuments)
            {
                <div class="tools-document">
                    <div class="tools-document-header">
                        <strong>@(string.IsNullOrEmpty(document.FileName) ? "(unnamed)" : document.FileName)</strong>
                        <span class="tools-document-meta">@document.PageCount page@(document.PageCount == 1 ? "" : "s")</span>
                    </div>

                    @foreach (var documentPage in document.Pages)
                    {
                        <div class="tools-document-page">
                            <div class="tools-page-label">Page @documentPage.PageNumber — @documentPage.Lines.Count line@(documentPage.Lines.Count == 1 ? "" : "s")</div>
                            @if (documentPage.Lines.Count > 0)
                            {
                                <pre class="tools-ocr-block">@string.Join("\n", documentPage.Lines)</pre>
                            }
                            else
                            {
                                <div class="tools-empty">No text detected.</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @{
        var documentsWithInvoiceData = _scannedDocuments.Where(document => document.Invoice is not null).ToList();
    }
    @if (documentsWithInvoiceData.Count > 0)
    {
        <div class="tools-card">
            <h5 class="m-0 mb-2">Invoice Fields (@documentsWithInvoiceData.Count)</h5>
            <p class="tools-hint">
                Structured key/value pairs extracted by the Azure
                <code>prebuilt-invoice</code> model. Empty fields mean the model
                didn't find a confident match for that key.
            </p>

            @foreach (var document in documentsWithInvoiceData)
            {
                var invoiceData = document.Invoice!;
                <div class="tools-document">
                    <div class="tools-document-header">
                        <strong>@(string.IsNullOrEmpty(document.FileName) ? "(unnamed)" : document.FileName)</strong>
                        @if (!string.IsNullOrWhiteSpace(invoiceData.CurrencyCode))
                        {
                            <span class="tools-document-meta">Currency: @invoiceData.CurrencyCode</span>
                        }
                    </div>

                    <div class="tools-invoice-grid">
                        @RenderInvoiceField("Vendor name", invoiceData.VendorName)
                        @RenderInvoiceField("Vendor address", invoiceData.VendorAddress)
                        @RenderInvoiceField("Vendor address recipient", invoiceData.VendorAddressRecipient)

                        @RenderInvoiceField("Customer name", invoiceData.CustomerName)
                        @RenderInvoiceField("Customer id", invoiceData.CustomerId)
                        @RenderInvoiceField("Customer address", invoiceData.CustomerAddress)
                        @RenderInvoiceField("Customer address recipient", invoiceData.CustomerAddressRecipient)

                        @RenderInvoiceField("Billing address", invoiceData.BillingAddress)
                        @RenderInvoiceField("Billing address recipient", invoiceData.BillingAddressRecipient)
                        @RenderInvoiceField("Shipping address", invoiceData.ShippingAddress)
                        @RenderInvoiceField("Shipping address recipient", invoiceData.ShippingAddressRecipient)
                        @RenderInvoiceField("Service address", invoiceData.ServiceAddress)
                        @RenderInvoiceField("Service address recipient", invoiceData.ServiceAddressRecipient)
                        @RenderInvoiceField("Remittance address", invoiceData.RemittanceAddress)
                        @RenderInvoiceField("Remittance address recipient", invoiceData.RemittanceAddressRecipient)

                        @RenderInvoiceField("Invoice id", invoiceData.InvoiceId)
                        @RenderInvoiceField("Invoice date", FormatInvoiceDate(invoiceData.InvoiceDate))
                        @RenderInvoiceField("Due date", FormatInvoiceDate(invoiceData.DueDate))
                        @RenderInvoiceField("Purchase order", invoiceData.PurchaseOrder)
                        @RenderInvoiceField("Service start date", FormatInvoiceDate(invoiceData.ServiceStartDate))
                        @RenderInvoiceField("Service end date", FormatInvoiceDate(invoiceData.ServiceEndDate))
                        @RenderInvoiceField("Payment term", invoiceData.PaymentTerm)

                        @RenderInvoiceField("Subtotal", FormatInvoiceAmount(invoiceData.SubTotal, invoiceData.CurrencyCode))
                        @RenderInvoiceField("Total tax", FormatInvoiceAmount(invoiceData.TotalTax, invoiceData.CurrencyCode))
                        @RenderInvoiceField("Invoice total", FormatInvoiceAmount(invoiceData.InvoiceTotal, invoiceData.CurrencyCode))
                        @RenderInvoiceField("Amount due", FormatInvoiceAmount(invoiceData.AmountDue, invoiceData.CurrencyCode))
                        @RenderInvoiceField("Previous unpaid balance", FormatInvoiceAmount(invoiceData.PreviousUnpaidBalance, invoiceData.CurrencyCode))
                    </div>

                    @if (invoiceData is HooverInvoiceData hooverInvoiceData && hooverInvoiceData.EquipmentPieces.Count > 0)
                    {
                        <div class="tools-subhead">Equipment pieces (@hooverInvoiceData.EquipmentPieces.Count)</div>
                        <table class="tools-stats-table">
                            <thead>
                                <tr>
                                    <th class="num">ID</th>
                                    <th class="num">Fuel quantity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var equipmentPiece in hooverInvoiceData.EquipmentPieces)
                                {
                                    <tr>
                                        <td class="num">@equipmentPiece.Id</td>
                                        <td class="num">@equipmentPiece.FuelQuantity.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @if (invoiceData.LineItems.Count > 0)
                    {
                        <div class="tools-subhead">Line items (@invoiceData.LineItems.Count)</div>
                        <table class="tools-stats-table">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th>Product</th>
                                    <th class="num">Qty</th>
                                    <th>Unit</th>
                                    <th class="num">Unit price</th>
                                    <th class="num">Tax</th>
                                    <th class="num">Tax rate</th>
                                    <th class="num">Amount</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lineItem in invoiceData.LineItems)
                                {
                                    <tr>
                                        <td>@(lineItem.Description ?? "—")</td>
                                        <td>@(lineItem.ProductCode ?? "—")</td>
                                        <td class="num">@FormatInvoiceNumber(lineItem.Quantity)</td>
                                        <td>@(lineItem.Unit ?? "—")</td>
                                        <td class="num">@FormatInvoiceAmount(lineItem.UnitPrice, invoiceData.CurrencyCode)</td>
                                        <td class="num">@FormatInvoiceAmount(lineItem.Tax, invoiceData.CurrencyCode)</td>
                                        <td class="num">@FormatInvoiceNumber(lineItem.TaxRate)</td>
                                        <td class="num">@FormatInvoiceAmount(lineItem.Amount, invoiceData.CurrencyCode)</td>
                                        <td>@FormatInvoiceDate(lineItem.Date)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    }

    <div class="tools-section-divider">
        <span class="tools-section-divider-label">Analytics</span>
    </div>

    <div class="tools-card tools-card--stats">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="m-0">Delivery Time Statistics</h5>
            <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                    @onclick="LoadDeliveryStats"
                    disabled="@_statsLoading">
                @(_statsLoading ? "Loading…" : "Refresh")
            </button>
        </div>
        <p class="tools-hint">
            Aggregate stats over every recorded delivery time. Filter by date
            range; the leaderboards weight slowest stops by mean time and
            require at least two samples so single outliers can't take a slot.
        </p>

        <div class="tools-stats-filters">
            <div class="admin-field" style="max-width: 160px;">
                <label>From</label>
                <input type="date" class="form-control form-control-sm"
                       @bind="_statsFrom" disabled="@_statsLoading" />
            </div>
            <div class="admin-field" style="max-width: 160px;">
                <label>To</label>
                <input type="date" class="form-control form-control-sm"
                       @bind="_statsTo" disabled="@_statsLoading" />
            </div>
            <div class="tools-stats-presets">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="() => ApplyDatePreset(7)" disabled="@_statsLoading">7d</button>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="() => ApplyDatePreset(30)" disabled="@_statsLoading">30d</button>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="() => ApplyDatePreset(90)" disabled="@_statsLoading">90d</button>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="ApplyAllTimePreset" disabled="@_statsLoading">All</button>
            </div>
            <button class="btn btn-sm btn-primary"
                    @onclick="LoadDeliveryStats" disabled="@_statsLoading">
                Apply
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_statsError))
        {
            <div class="text-warning mt-2" style="font-size:0.8rem;">@_statsError</div>
        }

        @if (_stats is null)
        {
            <div class="tools-empty mt-3">No stats loaded yet.</div>
        }
        else if (_stats.SampleCount == 0)
        {
            <div class="tools-empty mt-3">
                No delivery times recorded in the selected range.
            </div>
        }
        else
        {
            <div class="tools-stats-range">
                @_stats.SampleCount sample@(_stats.SampleCount == 1 ? "" : "s") •
                @FormatRecordedRange(_stats.OldestRecordedAt, _stats.NewestRecordedAt) •
                @_stats.GeofencedSampleCount geofenced / @_stats.LongRunningSampleCount long-running
            </div>

            <div class="tools-stats-grid">
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Mean</span>
                    <span class="tools-stat-value">@FormatDuration(_stats.MeanSeconds)</span>
                </div>
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Median</span>
                    <span class="tools-stat-value">@FormatDuration(_stats.MedianSeconds)</span>
                </div>
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Std. Dev.</span>
                    <span class="tools-stat-value">@FormatDuration(_stats.StandardDeviationSeconds)</span>
                </div>
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Fastest</span>
                    <span class="tools-stat-value">@FormatDuration(_stats.MinimumSeconds)</span>
                </div>
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Slowest</span>
                    <span class="tools-stat-value">@FormatDuration(_stats.MaximumSeconds)</span>
                </div>
                <div class="tools-stat-tile">
                    <span class="tools-stat-label">Total time</span>
                    <span class="tools-stat-value">@FormatHoursMinutes(_stats.TotalSeconds)</span>
                </div>
            </div>

            <div class="tools-subhead">Distribution</div>
            <div class="tools-histogram">
                @{
                    var maxBucketCount = _stats.Distribution.Count == 0 ? 0 : _stats.Distribution.Max(bucket => bucket.Count);
                }
                @foreach (var bucket in _stats.Distribution)
                {
                    var widthPercent = maxBucketCount == 0 ? 0 : (bucket.Count * 100.0 / maxBucketCount);
                    <div class="tools-histogram-row">
                        <span class="tools-histogram-label">@bucket.Label</span>
                        <div class="tools-histogram-track">
                            <div class="tools-histogram-bar" style="width:@(widthPercent.ToString("0.##"))%"></div>
                        </div>
                        <span class="tools-histogram-count">
                            @bucket.Count (@bucket.Percentage.ToString("0.#")%)
                        </span>
                    </div>
                }
            </div>

            <div class="tools-leaderboards">
                <div class="tools-leaderboard">
                    <div class="tools-subhead">Slowest addresses</div>
                    @if (_stats.SlowestAddresses.Count == 0)
                    {
                        <div class="tools-empty">Not enough repeat stops yet (need ≥ 2 samples).</div>
                    }
                    else
                    {
                        <table class="tools-stats-table">
                            <thead>
                                <tr>
                                    <th>Address</th>
                                    <th class="num">N</th>
                                    <th class="num">Mean</th>
                                    <th class="num">Median</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var slowAddress in _stats.SlowestAddresses)
                                {
                                    <tr>
                                        <td>
                                            @slowAddress.Street, @slowAddress.City @slowAddress.State
                                            @if (slowAddress.IsLongRunning)
                                            {
                                                <span class="tools-tag tools-tag--lr" title="Manual start/stop, not geofenced">LR</span>
                                            }
                                        </td>
                                        <td class="num">@slowAddress.SampleCount</td>
                                        <td class="num">@FormatDuration(slowAddress.MeanSeconds)</td>
                                        <td class="num">@FormatDuration(slowAddress.MedianSeconds)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="tools-leaderboard">
                    <div class="tools-subhead">Most-frequent addresses</div>
                    @if (_stats.MostFrequentAddresses.Count == 0)
                    {
                        <div class="tools-empty">No addresses to rank yet.</div>
                    }
                    else
                    {
                        <table class="tools-stats-table">
                            <thead>
                                <tr>
                                    <th>Address</th>
                                    <th class="num">N</th>
                                    <th class="num">Mean</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var frequentAddress in _stats.MostFrequentAddresses)
                                {
                                    <tr>
                                        <td>
                                            @frequentAddress.Street, @frequentAddress.City @frequentAddress.State
                                            @if (frequentAddress.IsLongRunning)
                                            {
                                                <span class="tools-tag tools-tag--lr" title="Manual start/stop, not geofenced">LR</span>
                                            }
                                        </td>
                                        <td class="num">@frequentAddress.SampleCount</td>
                                        <td class="num">@FormatDuration(frequentAddress.MeanSeconds)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _scanning;
    private string? _scanStatus;
    private bool _scanStatusSuccess;
    private string? _scanProgress;

    // Bumped to remount the <input type="file"> when we want to clear its
    // current selection — either after a scan completes or when the user
    // explicitly hits "Clear selection".
    private int _fileInputKey;

    // The model the user wants Azure Document Intelligence to run against.
    // Defaults to Read (general OCR) so the page works out of the box.
    private AzureDocumentIntelligenceModel _selectedModel = AzureDocumentIntelligenceModel.Read;

    // Selects which company's invoice schema the parser should map the
    // Azure response into. Only meaningful when _selectedModel is Invoice;
    // the dropdown is hidden otherwise. Generic keeps the plain InvoiceData
    // shape, vendor-specific values (e.g. Hoover) opt into a derived class.
    private CompanyInvoiceType _selectedCompanyInvoiceType = CompanyInvoiceType.Generic;

    private readonly List<string> _selectedFileNames = new();
    private readonly List<OcrDocumentDto> _scannedDocuments = new();

    // Hoover two-image flow: file inputs are split so the user is forced to
    // disambiguate which image is which. Keys bump on clear so the remount
    // resets the picker, same pattern as _fileInputKey above.
    private string? _hooverEquipmentImageFileName;
    private string? _hooverInvoiceImageFileName;
    private int _hooverEquipmentInputKey;
    private int _hooverInvoiceInputKey;

    private bool IsHooverScanFlow =>
        _selectedModel == AzureDocumentIntelligenceModel.Invoice
        && _selectedCompanyInvoiceType == CompanyInvoiceType.Hoover;

    private bool HasBothHooverImagesSelected =>
        !string.IsNullOrEmpty(_hooverEquipmentImageFileName)
        && !string.IsNullOrEmpty(_hooverInvoiceImageFileName);

    // Delivery-time analytics section state. Default window is "last 30 days"
    // so the page lands with something interesting to look at without
    // pulling the entire history on first load.
    private DeliveryTimeStatsDto? _stats;
    private bool _statsLoading;
    private string? _statsError;
    private DateTime? _statsFrom = DateTime.UtcNow.Date.AddDays(-30);
    private DateTime? _statsTo;

    protected override async Task OnInitializedAsync()
    {
        await LoadDeliveryStats();
    }

    // Mirrors the shape returned by readAllDispatchFilesAsBase64. The JS
    // helper is fully generic (input id → base64 file list), not
    // Dispatch-specific, so reusing it here is fine.
    private sealed record ToolsImageFile(
        [property: System.Text.Json.Serialization.JsonPropertyName("base64")] string Base64,
        [property: System.Text.Json.Serialization.JsonPropertyName("contentType")] string ContentType,
        [property: System.Text.Json.Serialization.JsonPropertyName("fileName")] string FileName,
        [property: System.Text.Json.Serialization.JsonPropertyName("size")] long Size);

    // Only stash the picked file names — the full base64 read and the
    // (paid) Document Intelligence call don't happen until the user
    // explicitly hits Scan.
    private async Task OnFileSelected()
    {
        _selectedFileNames.Clear();
        _scanStatus = null;
        _scanStatusSuccess = false;
        StateHasChanged();

        try
        {
            var names = await JS.InvokeAsync<string[]?>(
                "getDispatchFileNames", "tools-document-file");

            if (names is null || names.Length == 0) return;

            _selectedFileNames.AddRange(
                names.OrderBy(name => name ?? string.Empty, StringComparer.OrdinalIgnoreCase));
        }
        catch (Exception ex)
        {
            _scanStatus = $"Error reading selection: {ex.Message}";
            _scanStatusSuccess = false;
        }
    }

    private async Task OnScanClicked()
    {
        if (_selectedFileNames.Count == 0) return;

        _scanning = true;
        _scanStatus = null;
        _scanProgress = null;
        StateHasChanged();

        var perFileErrors = new List<string>();
        var addedCount = 0;

        try
        {
            // Re-read the picker right before scanning so we operate on
            // exactly what the user has selected now — even if they swapped
            // the picker contents after the initial selection.
            var imageFiles = await JS.InvokeAsync<ToolsImageFile[]?>(
                "readAllDispatchFilesAsBase64", "tools-document-file");

            if (imageFiles is null || imageFiles.Length == 0)
            {
                _scanStatus = "No file selected.";
                _scanStatusSuccess = false;
                return;
            }

            if (imageFiles.Length > 1)
            {
                imageFiles = imageFiles
                    .OrderBy(file => file.FileName ?? string.Empty, StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            }

            const long maxBytes = 10 * 1024 * 1024;

            for (var fileIndex = 0; fileIndex < imageFiles.Length; fileIndex++)
            {
                var imageFile = imageFiles[fileIndex];
                var label = string.IsNullOrEmpty(imageFile.FileName) ? $"file #{fileIndex + 1}" : imageFile.FileName;
                _scanProgress = $"Scanning file {fileIndex + 1} of {imageFiles.Length}…";
                StateHasChanged();

                if (string.IsNullOrEmpty(imageFile.Base64))
                {
                    perFileErrors.Add($"{label}: empty file.");
                    continue;
                }

                if (imageFile.Size > maxBytes)
                {
                    perFileErrors.Add($"{label}: exceeds 10 MB.");
                    continue;
                }

                try
                {
                    var bytes = Convert.FromBase64String(imageFile.Base64);
                    using var content = new MultipartFormDataContent();
                    var byteContent = new ByteArrayContent(bytes);
                    byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                        string.IsNullOrEmpty(imageFile.ContentType) ? "application/octet-stream" : imageFile.ContentType);
                    content.Add(byteContent, "file", string.IsNullOrEmpty(imageFile.FileName) ? "document" : imageFile.FileName);

                    var response = await Http.PostAsync(
                        $"api/imports/tools-document?model={_selectedModel}", content);

                    if (!response.IsSuccessStatusCode)
                    {
                        var body = await response.Content.ReadAsStringAsync();
                        perFileErrors.Add($"{label}: {(int)response.StatusCode} {response.StatusCode} — {body}");
                        continue;
                    }

                    var parsedDocument = await response.Content.ReadFromJsonAsync<OcrDocumentDto>();
                    if (parsedDocument is not null)
                    {
                        if (string.IsNullOrEmpty(parsedDocument.FileName))
                            parsedDocument.FileName = imageFile.FileName ?? string.Empty;

                        _scannedDocuments.Add(parsedDocument);
                        addedCount++;
                    }
                }
                catch (Exception ex)
                {
                    var detail = ex.InnerException is null ? ex.Message : $"{ex.Message} — {ex.InnerException.Message}";
                    perFileErrors.Add($"{label}: {detail}");
                }
            }

            var statusParts = new List<string>
            {
                $"Scanned {addedCount} of {imageFiles.Length} file{(imageFiles.Length == 1 ? "" : "s")}."
            };
            if (perFileErrors.Count > 0) statusParts.Add("Errors: " + string.Join(" | ", perFileErrors));

            _scanStatus = string.Join(" ", statusParts);
            _scanStatusSuccess = addedCount > 0 && perFileErrors.Count == 0;
        }
        catch (Exception ex)
        {
            var detail = ex.InnerException is null ? ex.Message : $"{ex.Message} — {ex.InnerException.Message}";
            _scanStatus = $"Error: {detail}";
            _scanStatusSuccess = false;
        }
        finally
        {
            _scanning = false;
            _scanProgress = null;
            _selectedFileNames.Clear();
            _fileInputKey++;
        }
    }

    private void ClearSelection()
    {
        _selectedFileNames.Clear();
        _scanStatus = null;
        _fileInputKey++;
    }

    private async Task OnHooverEquipmentImageSelected()
    {
        _hooverEquipmentImageFileName = await ReadSingleFileName("tools-hoover-equipment-file");
        _scanStatus = null;
    }

    private async Task OnHooverInvoiceImageSelected()
    {
        _hooverInvoiceImageFileName = await ReadSingleFileName("tools-hoover-invoice-file");
        _scanStatus = null;
    }

    private async Task<string?> ReadSingleFileName(string inputElementId)
    {
        try
        {
            var fileNames = await JS.InvokeAsync<string[]?>("getDispatchFileNames", inputElementId);
            return fileNames is { Length: > 0 } ? fileNames[0] : null;
        }
        catch (Exception ex)
        {
            _scanStatus = $"Error reading selection: {ex.Message}";
            _scanStatusSuccess = false;
            return null;
        }
    }

    private void ClearHooverSelection()
    {
        _hooverEquipmentImageFileName = null;
        _hooverInvoiceImageFileName = null;
        _hooverEquipmentInputKey++;
        _hooverInvoiceInputKey++;
        _scanStatus = null;
    }

    private async Task OnHooverScanClicked()
    {
        if (!HasBothHooverImagesSelected) return;

        _scanning = true;
        _scanStatus = null;
        _scanProgress = "Reading equipment image and invoice image…";
        StateHasChanged();

        try
        {
            // Re-read both pickers at scan time so we operate on whatever
            // the user currently has selected, even if they swapped files
            // after the initial selection.
            var equipmentImageFiles = await JS.InvokeAsync<ToolsImageFile[]?>(
                "readAllDispatchFilesAsBase64", "tools-hoover-equipment-file");
            var invoiceImageFiles = await JS.InvokeAsync<ToolsImageFile[]?>(
                "readAllDispatchFilesAsBase64", "tools-hoover-invoice-file");

            if (equipmentImageFiles is null || equipmentImageFiles.Length == 0
                || invoiceImageFiles is null || invoiceImageFiles.Length == 0)
            {
                _scanStatus = "Both an equipment image and an invoice image are required.";
                _scanStatusSuccess = false;
                return;
            }

            var equipmentImageFile = equipmentImageFiles[0];
            var invoiceImageFile = invoiceImageFiles[0];

            const long maxBytes = 10 * 1024 * 1024;
            if (equipmentImageFile.Size > maxBytes || invoiceImageFile.Size > maxBytes)
            {
                _scanStatus = "Each image must be 10 MB or smaller.";
                _scanStatusSuccess = false;
                return;
            }

            using var multipartContent = new MultipartFormDataContent();
            AppendImagePart(multipartContent, equipmentImageFile, "equipmentImage");
            AppendImagePart(multipartContent, invoiceImageFile, "invoiceImage");

            var response = await Http.PostAsync("api/imports/tools-hoover-invoice", multipartContent);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _scanStatus = $"{(int)response.StatusCode} {response.StatusCode} — {body}";
                _scanStatusSuccess = false;
                return;
            }

            var scannedDocument = await response.Content.ReadFromJsonAsync<OcrDocumentDto>();
            if (scannedDocument is not null)
            {
                _scannedDocuments.Add(scannedDocument);
                _scanStatus = "Hoover invoice scanned.";
                _scanStatusSuccess = true;
            }
        }
        catch (Exception ex)
        {
            var detail = ex.InnerException is null ? ex.Message : $"{ex.Message} — {ex.InnerException.Message}";
            _scanStatus = $"Error: {detail}";
            _scanStatusSuccess = false;
        }
        finally
        {
            _scanning = false;
            _scanProgress = null;
            ClearHooverSelection();
        }
    }

    private static void AppendImagePart(MultipartFormDataContent multipartContent, ToolsImageFile imageFile, string fieldName)
    {
        var imageBytes = Convert.FromBase64String(imageFile.Base64);
        var byteArrayContent = new ByteArrayContent(imageBytes);
        byteArrayContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
            string.IsNullOrEmpty(imageFile.ContentType) ? "application/octet-stream" : imageFile.ContentType);
        multipartContent.Add(byteArrayContent, fieldName,
            string.IsNullOrEmpty(imageFile.FileName) ? fieldName : imageFile.FileName);
    }

    private void ClearScannedDocuments()
    {
        _scannedDocuments.Clear();
        _scanStatus = null;
    }

    private async Task LoadDeliveryStats()
    {
        _statsLoading = true;
        _statsError = null;
        StateHasChanged();

        try
        {
            var queryParameters = new List<string>();
            if (_statsFrom.HasValue)
                queryParameters.Add($"from={Uri.EscapeDataString(DateTime.SpecifyKind(_statsFrom.Value.Date, DateTimeKind.Utc).ToString("O"))}");
            if (_statsTo.HasValue)
                queryParameters.Add($"to={Uri.EscapeDataString(DateTime.SpecifyKind(_statsTo.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Utc).ToString("O"))}");

            var queryString = queryParameters.Count == 0 ? string.Empty : "?" + string.Join("&", queryParameters);
            _stats = await Http.GetFromJsonAsync<DeliveryTimeStatsDto>($"api/delivery-times/stats{queryString}");
        }
        catch (Exception ex)
        {
            _statsError = $"Failed to load stats: {ex.Message}";
            _stats = null;
        }
        finally
        {
            _statsLoading = false;
        }
    }

    private async Task ApplyDatePreset(int daysBack)
    {
        _statsFrom = DateTime.UtcNow.Date.AddDays(-daysBack);
        _statsTo = null;
        await LoadDeliveryStats();
    }

    private async Task ApplyAllTimePreset()
    {
        _statsFrom = null;
        _statsTo = null;
        await LoadDeliveryStats();
    }

    private static string FormatDuration(double totalSeconds)
    {
        if (totalSeconds < 0) totalSeconds = 0;
        var span = TimeSpan.FromSeconds(totalSeconds);
        // Anything under an hour reads as mm:ss; an hour or more gets h:mm:ss.
        return span.TotalHours >= 1
            ? $"{(int)span.TotalHours}:{span.Minutes:00}:{span.Seconds:00}"
            : $"{span.Minutes}:{span.Seconds:00}";
    }

    private static string FormatHoursMinutes(double totalSeconds)
    {
        if (totalSeconds < 0) totalSeconds = 0;
        var span = TimeSpan.FromSeconds(totalSeconds);
        if (span.TotalHours >= 1)
            return $"{(int)span.TotalHours}h {span.Minutes}m";
        if (span.TotalMinutes >= 1)
            return $"{span.Minutes}m {span.Seconds}s";
        return $"{span.Seconds}s";
    }

    // Renders a single "label: value" row in the invoice grid. Centralized
    // here so every property uses the same markup and missing values render
    // identically (em dash, muted color).
    private static RenderFragment RenderInvoiceField(string label, string? value) => builder =>
    {
        var hasValue = !string.IsNullOrWhiteSpace(value);
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "tools-invoice-field");

        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "tools-invoice-field-label");
        builder.AddContent(4, label);
        builder.CloseElement();

        builder.OpenElement(5, "span");
        builder.AddAttribute(6, "class", hasValue ? "tools-invoice-field-value" : "tools-invoice-field-value tools-invoice-field-value--missing");
        builder.AddContent(7, hasValue ? value : "—");
        builder.CloseElement();

        builder.CloseElement();
    };

    private static string? FormatInvoiceDate(DateTime? date) =>
        date.HasValue ? date.Value.ToString("yyyy-MM-dd") : null;

    private static string? FormatInvoiceAmount(decimal? amount, string? currencyCode)
    {
        if (!amount.HasValue) return null;
        var formatted = amount.Value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);
        return string.IsNullOrWhiteSpace(currencyCode) ? formatted : $"{formatted} {currencyCode}";
    }

    private static string? FormatInvoiceNumber(decimal? number) =>
        number.HasValue ? number.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : null;

    private static string FormatRecordedRange(DateTime? oldest, DateTime? newest)
    {
        if (!oldest.HasValue || !newest.HasValue) return "no records";
        var oldestLocal = oldest.Value.ToLocalTime();
        var newestLocal = newest.Value.ToLocalTime();
        return oldestLocal.Date == newestLocal.Date
            ? oldestLocal.ToString("yyyy-MM-dd")
            : $"{oldestLocal:yyyy-MM-dd} → {newestLocal:yyyy-MM-dd}";
    }
}
