@page "/tools"
@using PropaneDriver.Shared.Dtos
@inject HttpClient Http
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]

<PageTitle>Tools</PageTitle>

<div class="tools-page">
    <h4 class="tools-title">Tools</h4>

    <div class="tools-card">
        <h5>Document Scanner</h5>
        <p class="tools-hint">
            Upload one or more image files. Each file is run through Azure Document
            Intelligence and the raw OCR lines per page are shown below.
        </p>

        <div class="admin-row">
            <div class="admin-field flex-2">
                <label>Select image file(s)</label>
                <input type="file" id="tools-document-file" @key="_fileInputKey"
                       accept="image/*" multiple class="form-control form-control-sm"
                       @onchange="OnFileSelected" />
            </div>
        </div>

        @if (_scanning)
        {
            <div class="d-flex align-items-center gap-2 mt-2" style="font-size:0.8rem; color:#8892b0;">
                <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                <span>@(_scanProgress ?? "Reading files…")</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(_scanStatus))
        {
            <div class="@(_scanStatusSuccess ? "text-success" : "text-warning") mt-2"
                 style="font-size:0.8rem;">
                @_scanStatus
            </div>
        }
    </div>

    @if (_scannedDocuments.Count > 0)
    {
        <div class="tools-card">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="m-0">Scanned Documents (@_scannedDocuments.Count)</h5>
                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                        @onclick="ClearScannedDocuments">
                    Clear
                </button>
            </div>

            @foreach (var document in _scannedDocuments)
            {
                <div class="tools-document">
                    <div class="tools-document-header">
                        <strong>@(string.IsNullOrEmpty(document.FileName) ? "(unnamed)" : document.FileName)</strong>
                        <span class="tools-document-meta">@document.PageCount page@(document.PageCount == 1 ? "" : "s")</span>
                    </div>

                    @foreach (var documentPage in document.Pages)
                    {
                        <div class="tools-document-page">
                            <div class="tools-page-label">Page @documentPage.PageNumber — @documentPage.Lines.Count line@(documentPage.Lines.Count == 1 ? "" : "s")</div>
                            @if (documentPage.Lines.Count > 0)
                            {
                                <pre class="tools-ocr-block">@string.Join("\n", documentPage.Lines)</pre>
                            }
                            else
                            {
                                <div class="tools-empty">No text detected.</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _scanning;
    private string? _scanStatus;
    private bool _scanStatusSuccess;
    private string? _scanProgress;

    // Bumped after every upload attempt so the <input type="file"> remounts
    // and the browser's prior selection can't be silently reused.
    private int _fileInputKey;

    private readonly List<OcrDocumentDto> _scannedDocuments = new();

    // Mirrors the shape returned by readAllDispatchFilesAsBase64 — we reuse
    // that JS helper here since it's already a generic
    // (input id) -> base64-file-list reader, not Dispatch-specific.
    private sealed record ToolsImageFile(
        [property: System.Text.Json.Serialization.JsonPropertyName("base64")] string Base64,
        [property: System.Text.Json.Serialization.JsonPropertyName("contentType")] string ContentType,
        [property: System.Text.Json.Serialization.JsonPropertyName("fileName")] string FileName,
        [property: System.Text.Json.Serialization.JsonPropertyName("size")] long Size);

    private async Task OnFileSelected()
    {
        _scanning = true;
        _scanStatus = null;
        _scanProgress = null;
        StateHasChanged();

        var perFileErrors = new List<string>();
        var addedCount = 0;

        try
        {
            var imageFiles = await JS.InvokeAsync<ToolsImageFile[]?>(
                "readAllDispatchFilesAsBase64", "tools-document-file");

            if (imageFiles is null || imageFiles.Length == 0)
            {
                _scanStatus = "No file selected.";
                _scanStatusSuccess = false;
                return;
            }

            // Sort by filename so multi-file scans show up in a predictable
            // order regardless of how the OS handed them to us.
            if (imageFiles.Length > 1)
            {
                imageFiles = imageFiles
                    .OrderBy(file => file.FileName ?? string.Empty, StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            }

            const long maxBytes = 10 * 1024 * 1024;

            for (var fileIndex = 0; fileIndex < imageFiles.Length; fileIndex++)
            {
                var imageFile = imageFiles[fileIndex];
                var label = string.IsNullOrEmpty(imageFile.FileName) ? $"file #{fileIndex + 1}" : imageFile.FileName;
                _scanProgress = $"Reading file {fileIndex + 1} of {imageFiles.Length}…";
                StateHasChanged();

                if (string.IsNullOrEmpty(imageFile.Base64))
                {
                    perFileErrors.Add($"{label}: empty file.");
                    continue;
                }

                if (imageFile.Size > maxBytes)
                {
                    perFileErrors.Add($"{label}: exceeds 10 MB.");
                    continue;
                }

                try
                {
                    var bytes = Convert.FromBase64String(imageFile.Base64);
                    using var content = new MultipartFormDataContent();
                    var byteContent = new ByteArrayContent(bytes);
                    byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                        string.IsNullOrEmpty(imageFile.ContentType) ? "application/octet-stream" : imageFile.ContentType);
                    content.Add(byteContent, "file", string.IsNullOrEmpty(imageFile.FileName) ? "document" : imageFile.FileName);

                    var response = await Http.PostAsync("api/imports/tools-document", content);

                    if (!response.IsSuccessStatusCode)
                    {
                        var body = await response.Content.ReadAsStringAsync();
                        perFileErrors.Add($"{label}: {(int)response.StatusCode} {response.StatusCode} — {body}");
                        continue;
                    }

                    var parsedDocument = await response.Content.ReadFromJsonAsync<OcrDocumentDto>();
                    if (parsedDocument is not null)
                    {
                        if (string.IsNullOrEmpty(parsedDocument.FileName))
                            parsedDocument.FileName = imageFile.FileName ?? string.Empty;

                        _scannedDocuments.Add(parsedDocument);
                        addedCount++;
                    }
                }
                catch (Exception ex)
                {
                    var detail = ex.InnerException is null ? ex.Message : $"{ex.Message} — {ex.InnerException.Message}";
                    perFileErrors.Add($"{label}: {detail}");
                }
            }

            var statusParts = new List<string>
            {
                $"Scanned {addedCount} of {imageFiles.Length} file{(imageFiles.Length == 1 ? "" : "s")}."
            };
            if (perFileErrors.Count > 0) statusParts.Add("Errors: " + string.Join(" | ", perFileErrors));

            _scanStatus = string.Join(" ", statusParts);
            _scanStatusSuccess = addedCount > 0 && perFileErrors.Count == 0;
        }
        catch (Exception ex)
        {
            var detail = ex.InnerException is null ? ex.Message : $"{ex.Message} — {ex.InnerException.Message}";
            _scanStatus = $"Error: {detail}";
            _scanStatusSuccess = false;
        }
        finally
        {
            _scanning = false;
            _scanProgress = null;
            _fileInputKey++;
        }
    }

    private void ClearScannedDocuments()
    {
        _scannedDocuments.Clear();
        _scanStatus = null;
    }
}
