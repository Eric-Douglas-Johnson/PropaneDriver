@page "/fuel-log"
@using PropaneDriver.Client.Services
@using PropaneDriver.Client.Authentication
@using PropaneDriver.Shared.Dtos
@using Microsoft.AspNetCore.Components.Authorization
@inject FuelLogApiService FuelLogApi
@inject SpeechService SpeechService
@inject BrowserStorageService BrowserStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

<PageTitle>Fuel Log</PageTitle>

<div class="fuel-log-page">
    @* Warn before navigating away (in-app or closing the tab) with edits that
       haven't reached the server, so a stray tap can't lose entered readings. *@
    <NavigationLock ConfirmExternalNavigation="IsDirty"
                    OnBeforeInternalNavigation="HandleInternalNavigationAsync" />

    <h4 class="fuel-log-title">Fuel Log</h4>

    <div class="fuel-log-card">

        @if (_loading)
        {
            <div class="fuel-log-status">Loading…</div>
        }
        else
        {
            <button class="btn fuel-log-lognext" @onclick="LogNextAsync" disabled="@(_listening || _saving)">
                <span class="fuel-log-lognext-icon">🎤</span>
                <span class="fuel-log-lognext-label">@(_listening ? "Listening…" : "Log Next")</span>
            </button>

            <div class="fuel-log-table">
                <div class="fuel-log-row fuel-log-row--head">
                    <span>#</span>
                    <span>Equip #</span>
                    <span>Meter</span>
                    <span>Gallons</span>
                    <span></span>
                </div>

                @for (var rowIndex = 0; rowIndex < _rows.Count; rowIndex++)
                {
                    var index = rowIndex; // capture for the remove handler
                    var row = _rows[index];
                    var isStartRow = index == 0;
                    var gallons = GallonsForRow(index);

                    <div class="fuel-log-row @(isStartRow ? "fuel-log-row--start" : "")" @key="row.Key">
                        <span class="fuel-log-rownum">@(isStartRow ? "" : index.ToString())</span>

                        @if (isStartRow)
                        {
                            <input class="form-control form-control-sm fuel-log-startlabel"
                                   type="text" value="Start" readonly tabindex="-1" />
                        }
                        else
                        {
                            <input class="form-control form-control-sm"
                                   placeholder="104"
                                   @bind="row.EquipmentNumber"
                                   @bind:after="MirrorDraftAfterEditAsync"
                                   @onfocus="() => ListenForEquipmentNumberAsync(index)" />
                        }

                        <input class="form-control form-control-sm" type="number" step="any"
                               inputmode="decimal" placeholder="0"
                               @bind="row.MeterValue" @bind:after="MirrorDraftAfterEditAsync" />
                        <input class="form-control form-control-sm fuel-log-gallons"
                               type="text" readonly tabindex="-1"
                               value="@(gallons.HasValue ? gallons.Value.ToString("0.##") : "—")" />

                        @if (isStartRow)
                        {
                            <span></span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger fuel-log-remove"
                                    @onclick="() => RemoveRow(index)"
                                    title="Remove row">×</button>
                        }
                    </div>
                }
            </div>

            <div class="fuel-log-actions">
                <button class="btn btn-outline-secondary fuel-log-action" @onclick="AddRow">+ Add row</button>
                <button class="btn btn-primary fuel-log-action" @onclick="SaveAsync" disabled="@_saving">
                    @(_saving ? "Saving…" : "Save fuel log")
                </button>
                <button class="btn btn-outline-warning fuel-log-action" @onclick="StartNewLogAsync" disabled="@_saving">
                    Start new log
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <div class="@(_statusSuccess ? "text-success" : "text-warning") fuel-log-savemsg">
                    @_statusMessage
                </div>
            }

            <div class="fuel-log-total">
                Total gallons pumped: <strong>@TotalGallons().ToString("0.##")</strong>
            </div>
        }
    </div>
</div>

@code {
    // Editable view of a single log row. GallonsPumped isn't stored here —
    // it's always derived from this row's and the previous row's meter values
    // via GallonsForRow, which is what makes the column auto-fill.
    private sealed class FuelLogRow
    {
        // Stable identity so Blazor keeps each row's inputs bound to the right
        // row when one is removed from the middle of the list.
        public Guid Key { get; } = Guid.NewGuid();
        public string Id { get; set; } = string.Empty;
        public string EquipmentNumber { get; set; } = string.Empty;
        public decimal? MeterValue { get; set; }
    }

    // On-device recovery draft. Mirrors the editable grid (nullable meter so a
    // blank row round-trips faithfully) plus whether these rows still need to
    // reach the server. Persisted to localStorage so entered readings survive a
    // reload or a failed save.
    private sealed class FuelLogDraft
    {
        public List<FuelLogDraftRow> Rows { get; set; } = new();
        public bool PendingSave { get; set; }
        public DateTime UpdatedAt { get; set; }
    }

    private sealed class FuelLogDraftRow
    {
        public string Id { get; set; } = string.Empty;
        public string EquipmentNumber { get; set; } = string.Empty;
        public decimal? MeterValue { get; set; }
        public int SortOrder { get; set; }
    }

    private readonly List<FuelLogRow> _rows = new();
    private bool _loading = true;
    private bool _saving;
    private bool _listening;
    private string? _statusMessage;
    private bool _statusSuccess;

    // localStorage key for this driver's on-device recovery draft, set once we
    // know who's signed in. Left empty (which disables the local mirror) if the
    // driver id isn't available, so two accounts never share one draft.
    private string _draftStorageKey = string.Empty;

    // Snapshot of the rows as they last matched what's persisted (taken after
    // load and after a successful save). The grid is "dirty" when the current
    // rows differ from it — that's what triggers the save prompt on New Log.
    private string _savedSignature = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var driverId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        _draftStorageKey = string.IsNullOrWhiteSpace(driverId) ? string.Empty : $"fuel-log-draft:{driverId}";

        var entries = await FuelLogApi.GetFuelLogAsync();
        foreach (var entry in entries.OrderBy(entry => entry.SortOrder))
        {
            // The meter column is stored NOT NULL, so a row saved with no
            // reading yet (e.g. an equipment number entered before its meter)
            // comes back as 0. Treat a non-start row's 0 as the blank it really
            // was: Log Next fills the first row whose meter is null, and a stray
            // 0 would hide that row and send the next reading to the wrong line.
            // A pump meter is cumulative and only climbs, so 0 on a later row is
            // never a real reading. Row 0 is the Start baseline, whose 0 is a
            // genuine starting meter, so it's left as-is.
            var isStartRow = _rows.Count == 0;
            _rows.Add(new FuelLogRow
            {
                Id = entry.Id,
                EquipmentNumber = entry.EquipmentNumber,
                MeterValue = (!isStartRow && entry.MeterValue == 0)
                    ? (decimal?)null
                    : entry.MeterValue
            });
        }

        EnsureStartRow();
        _savedSignature = CurrentSignature();

        // Recover any entries this device saved locally but never got onto the
        // server (a failed save, or the tab closed mid-save).
        await TryRestoreLocalDraftAsync();

        _loading = false;
    }

    // Order-sensitive fingerprint of the rows' editable content. Gallons is
    // derived, so only the equipment number and meter value matter for whether
    // the driver has unsaved changes.
    private string CurrentSignature() =>
        string.Join("\n", _rows.Select(row => $"{row.EquipmentNumber}|{row.MeterValue}"));

    private bool IsDirty => CurrentSignature() != _savedSignature;

    // Row 0 is always the "Start" baseline: a read-only label plus the meter
    // reading the driver began at (0 when starting fresh). It anchors the
    // gallons calc so the first real entry's gallons = its meter − the start
    // meter. We also keep at least one entry row beneath it to type into.
    private void EnsureStartRow()
    {
        if (_rows.Count == 0)
            _rows.Add(new FuelLogRow { EquipmentNumber = "Start", MeterValue = 0 });
        else
            _rows[0].EquipmentNumber = "Start";

        if (_rows.Count < 2)
            _rows.Add(new FuelLogRow());
    }

    // Gallons for a row = this row's meter − the previous row's meter, when
    // both readings are present. The first row (or any row missing a value)
    // has nothing to subtract from, so it returns null and renders an em dash.
    private decimal? GallonsForRow(int index)
    {
        if (index <= 0) return null;

        var currentMeter = _rows[index].MeterValue;
        var previousMeter = _rows[index - 1].MeterValue;
        if (currentMeter is null || previousMeter is null) return null;

        return currentMeter.Value - previousMeter.Value;
    }

    // Sum of the positive per-row gallons. Negative values (a meter reading
    // lower than the one above it — usually a typo) are left out of the total.
    private decimal TotalGallons()
    {
        decimal total = 0;
        for (var index = 0; index < _rows.Count; index++)
        {
            var gallons = GallonsForRow(index);
            if (gallons.HasValue && gallons.Value > 0) total += gallons.Value;
        }
        return total;
    }

    private void AddRow()
    {
        _rows.Add(new FuelLogRow());
        _statusMessage = null;
    }

    // Voice-capture the next meter reading and drop it into the next empty
    // meter box. "Next open" = the first row (top-down) whose meter is still
    // blank; if every row is filled we append a fresh one so the spoken value
    // isn't lost. The driver still types the equipment number themselves.
    private async Task LogNextAsync()
    {
        _listening = true;
        _statusMessage = null;
        StateHasChanged();

        var (spoken, error) = await SpeechService.DictateDetailedAsync();

        _listening = false;

        if (!string.IsNullOrEmpty(error))
        {
            _statusSuccess = false;
            _statusMessage = error switch
            {
                "no-speech" => "Didn't hear anything — tap Log Next and speak the meter reading.",
                "not-allowed" or "service-not-allowed" =>
                    "Microphone access is blocked. Allow it in your browser settings.",
                _ when error.Contains("not supported") =>
                    "Voice input isn't supported in this browser. On iPhone, use Safari, " +
                    "or tap the meter box and use the keyboard's microphone key.",
                _ => $"Voice input failed: {error}"
            };
            return;
        }

        if (string.IsNullOrWhiteSpace(spoken))
        {
            _statusSuccess = false;
            _statusMessage = "Didn't catch a meter reading — tap Log Next to try again.";
            return;
        }

        var meterValue = ParseMeterValue(spoken);
        if (meterValue is null)
        {
            _statusSuccess = false;
            _statusMessage = $"Couldn't read a number from \"{spoken}\".";
            return;
        }

        var targetRow = _rows.FirstOrDefault(row => row.MeterValue is null);
        if (targetRow is null)
        {
            targetRow = new FuelLogRow();
            _rows.Add(targetRow);
        }

        targetRow.MeterValue = meterValue;

        // Mirror the captured reading to this device so a reload can recover it,
        // but leave the actual save to the driver's Save fuel log tap.
        await PersistLocalDraftAsync(pendingSave: true);

        _statusSuccess = true;
        var gallons = GallonsForRow(_rows.IndexOf(targetRow));
        _statusMessage = gallons.HasValue
            ? $"Logged meter {meterValue.Value.ToString("0.##")} " +
              $"({gallons.Value.ToString("0.##")} gal)."
            : $"Logged meter {meterValue.Value.ToString("0.##")}.";
    }

    // Focusing into an empty Equip # box arms the recognizer and drops the
    // spoken digits into that row's field, so the driver doesn't have to type
    // the unit number with one hand on the pump. We only listen when the field
    // is blank — once a value's there (typed or dictated), re-focusing to edit
    // it shouldn't start a fresh capture. The _listening guard also keeps a
    // simultaneous Log Next capture from being clobbered.
    private async Task ListenForEquipmentNumberAsync(int rowIndex)
    {
        if (_listening || _saving) return;
        if (rowIndex <= 0 || rowIndex >= _rows.Count) return;

        var targetRow = _rows[rowIndex];
        if (!string.IsNullOrWhiteSpace(targetRow.EquipmentNumber)) return;

        _listening = true;
        _statusMessage = null;
        StateHasChanged();

        var (spoken, error) = await SpeechService.DictateDetailedAsync();

        _listening = false;

        if (!string.IsNullOrEmpty(error))
        {
            _statusSuccess = false;
            _statusMessage = error switch
            {
                "no-speech" => "Didn't hear anything — tap the Equip # box and speak the number.",
                "not-allowed" or "service-not-allowed" =>
                    "Microphone access is blocked. Allow it in your browser settings.",
                _ when error.Contains("not supported") =>
                    "Voice input isn't supported in this browser. On iPhone, use Safari, " +
                    "or type the equipment number on the keyboard.",
                _ => $"Voice input failed: {error}"
            };
            return;
        }

        if (string.IsNullOrWhiteSpace(spoken))
        {
            _statusSuccess = false;
            _statusMessage = "Didn't catch an equipment number — tap the field to try again.";
            return;
        }

        var equipmentNumber = ParseEquipmentNumber(spoken);
        if (string.IsNullOrEmpty(equipmentNumber))
        {
            _statusSuccess = false;
            _statusMessage = $"Couldn't read an equipment number from \"{spoken}\".";
            return;
        }

        targetRow.EquipmentNumber = equipmentNumber;

        // Mirror the captured unit number to this device, the same as a typed
        // edit. The driver saves explicitly with Save fuel log.
        await PersistLocalDraftAsync(pendingSave: true);
        _statusSuccess = true;
        _statusMessage = $"Logged equipment #{equipmentNumber}.";
    }

    // Equipment numbers look like "104" per the placeholder, so pull the first
    // digit run out of the spoken text — speech usually returns plain digits
    // but can carry grouping commas ("1,040") or trailing words. If no digits
    // come through at all, fall back to the trimmed text so the driver can fix
    // up an unusual unit label by hand rather than losing their dictation.
    private static string ParseEquipmentNumber(string spoken)
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            spoken.Replace(",", string.Empty), @"\d+");
        return match.Success ? match.Value : spoken.Trim();
    }

    // Pull the first numeric run out of the spoken text. Speech usually comes
    // back as plain digits ("104") but can carry grouping commas ("1,040") or
    // trailing words ("104 gallons"), so strip commas and match the first
    // number rather than parsing the whole string.
    private static decimal? ParseMeterValue(string spoken)
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            spoken.Replace(",", string.Empty), @"-?\d+(\.\d+)?");
        if (!match.Success) return null;

        return decimal.TryParse(
            match.Value,
            System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture,
            out var value)
            ? value
            : null;
    }

    private void RemoveRow(int index)
    {
        // Index 0 is the Start baseline and can't be removed.
        if (index <= 0 || index >= _rows.Count) return;

        _rows.RemoveAt(index);
        if (_rows.Count < 2) _rows.Add(new FuelLogRow());
        _statusMessage = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _statusMessage = null;
        StateHasChanged();

        // Capture exactly what we're about to send, before any await — both the
        // dto and its signature reflect the same instant. If a field is edited
        // while the request is in flight, that edit won't be falsely counted as
        // saved when the response comes back.
        var signatureBeingSaved = CurrentSignature();
        var saveDto = new SaveFuelLogDto
        {
            Entries = _rows.Select((row, index) => new FuelLogEntryDto
            {
                Id = row.Id,
                EquipmentNumber = row.EquipmentNumber?.Trim() ?? string.Empty,
                MeterValue = row.MeterValue ?? 0,
                GallonsPumped = GallonsForRow(index) ?? 0,
                SortOrder = index
            }).ToList()
        };

        // Snapshot to this device before the network round-trip, so a crash or
        // a closed tab mid-save can't lose the entries.
        await PersistLocalDraftAsync(pendingSave: true);

        var saved = await FuelLogApi.SaveFuelLogAsync(saveDto);

        _saving = false;
        _statusSuccess = saved;
        _statusMessage = saved ? "Saved." : "Save failed — try again.";
        if (saved) _savedSignature = signatureBeingSaved;

        // Record the result on-device. pendingSave reflects whether the current
        // grid still differs from what's now saved, so a row edited while the
        // save was in flight stays marked unsaved (and recoverable) instead of
        // being dropped.
        await PersistLocalDraftAsync(pendingSave: IsDirty);
    }

    // Mirror an edited meter or equipment field to this device's local storage.
    // @bind:after only fires when an input's value actually changed (it rides
    // the commit/change event), so tabbing through a field without editing won't
    // trigger this. Nothing reaches the server here — the driver saves
    // explicitly with the Save fuel log button — but the local mirror means a
    // reload before that save can still recover the entered readings.
    private async Task MirrorDraftAfterEditAsync()
    {
        await PersistLocalDraftAsync(pendingSave: true);
    }

    // Mirror the current grid to this device's local storage so entries survive
    // a reload or a save that errors out. pendingSave records whether these
    // rows still need to reach the server: true after an edit or a failed save,
    // false once the server has them. Best-effort — a storage hiccup must never
    // block or fail the real save.
    private async Task PersistLocalDraftAsync(bool pendingSave)
    {
        if (string.IsNullOrEmpty(_draftStorageKey)) return;

        try
        {
            var draft = new FuelLogDraft
            {
                PendingSave = pendingSave,
                UpdatedAt = DateTime.UtcNow,
                Rows = _rows.Select((row, index) => new FuelLogDraftRow
                {
                    Id = row.Id,
                    EquipmentNumber = row.EquipmentNumber,
                    MeterValue = row.MeterValue,
                    SortOrder = index
                }).ToList()
            };
            await BrowserStorage.SaveToStorageAsync(_draftStorageKey, draft);
        }
        catch
        {
            // The local mirror is a backstop, not the source of truth.
        }
    }

    // On load, recover entries a previous session left on this device but never
    // got onto the server. A draft already marked saved is just a stale mirror
    // of server state, so it's dropped.
    private async Task TryRestoreLocalDraftAsync()
    {
        if (string.IsNullOrEmpty(_draftStorageKey)) return;

        FuelLogDraft? draft;
        try
        {
            draft = await BrowserStorage.GetFromStorage<FuelLogDraft>(_draftStorageKey);
        }
        catch
        {
            return;
        }

        if (draft is null) return;

        if (!draft.PendingSave || draft.Rows.Count == 0)
        {
            await BrowserStorage.RemoveFromStorage(_draftStorageKey);
            return;
        }

        _rows.Clear();
        foreach (var row in draft.Rows.OrderBy(draftRow => draftRow.SortOrder))
        {
            _rows.Add(new FuelLogRow
            {
                Id = row.Id,
                EquipmentNumber = row.EquipmentNumber,
                MeterValue = row.MeterValue
            });
        }
        EnsureStartRow();

        // If the recovered rows already match what's saved, there was nothing to
        // recover — clear the stale draft and stay quiet. (_savedSignature still
        // reflects the server data loaded above, so this compares draft vs server.)
        if (CurrentSignature() == _savedSignature)
        {
            await BrowserStorage.RemoveFromStorage(_draftStorageKey);
            return;
        }

        _statusSuccess = false;
        _statusMessage =
            "Recovered unsaved entries from this device — tap Save fuel log to store them.";
    }

    // Warn before leaving the page in-app with edits that haven't reached the
    // server. The entries are also mirrored on this device, so leaving won't
    // lose them — but this gives the driver the chance to Save first. Closing
    // the tab / refreshing is covered by NavigationLock.ConfirmExternalNavigation.
    private async Task HandleInternalNavigationAsync(LocationChangingContext context)
    {
        if (!IsDirty) return;

        var leave = await JS.InvokeAsync<bool>(
            "confirm",
            "This fuel log has unsaved changes.\n\n" +
            "OK — leave this page (your entries are kept on this device).\n" +
            "Cancel — stay here so you can Save fuel log.");

        if (!leave) context.PreventNavigation();
    }

    // Clear the grid back to a fresh log (Start baseline + one empty entry)
    // and persist that blank log immediately so it's the canonical state on the
    // server, not just in the browser. If there are unsaved changes, give the
    // driver the chance to save them first so a stray click can't wipe out
    // un-persisted work.
    private async Task StartNewLogAsync()
    {
        if (IsDirty)
        {
            var saveFirst = await JS.InvokeAsync<bool>(
                "confirm",
                "This fuel log has unsaved changes.\n\n" +
                "OK — save them first, then start a new log.\n" +
                "Cancel — discard them and start a new log.");

            if (saveFirst)
            {
                await SaveAsync();
                // If the save didn't go through, keep the rows so nothing is lost.
                if (!_statusSuccess) return;
            }
        }

        _rows.Clear();
        EnsureStartRow();

        // Save the fresh blank log so it persists across reloads/devices. On
        // failure SaveAsync leaves its own "Save failed" message, so only
        // override the message when the save actually succeeded.
        await SaveAsync();
        if (_statusSuccess)
            _statusMessage = "Started a new fuel log.";
    }
}
