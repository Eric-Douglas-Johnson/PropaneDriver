@page "/fuel-log"
@using PropaneDriver.Client.Services
@using PropaneDriver.Shared.Dtos
@inject FuelLogApiService FuelLogApi
@inject SpeechService SpeechService
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "driver")]

<PageTitle>Fuel Log</PageTitle>

<div class="fuel-log-page">
    <h4 class="fuel-log-title">Fuel Log</h4>

    <div class="fuel-log-card">

        @if (_loading)
        {
            <div class="fuel-log-status">Loading…</div>
        }
        else
        {
            <button class="btn fuel-log-lognext" @onclick="LogNextAsync" disabled="@_listening">
                @(_listening ? "Listening…" : "🎤 Log Next")
            </button>

            <div class="fuel-log-table">
                <div class="fuel-log-row fuel-log-row--head">
                    <span>#</span>
                    <span>Equipment #</span>
                    <span>Meter value</span>
                    <span>Gallons pumped</span>
                    <span></span>
                </div>

                @for (var rowIndex = 0; rowIndex < _rows.Count; rowIndex++)
                {
                    var index = rowIndex; // capture for the remove handler
                    var row = _rows[index];
                    var isStartRow = index == 0;
                    var gallons = GallonsForRow(index);
                    <div class="fuel-log-row @(isStartRow ? "fuel-log-row--start" : "")" @key="row.Key">
                        <span class="fuel-log-rownum">@(isStartRow ? "" : index.ToString())</span>
                        @if (isStartRow)
                        {
                            <input class="form-control form-control-sm fuel-log-startlabel"
                                   type="text" value="Start" readonly tabindex="-1" />
                        }
                        else
                        {
                            <input class="form-control form-control-sm"
                                   placeholder="e.g. 104"
                                   @bind="row.EquipmentNumber" />
                        }
                        <input class="form-control form-control-sm" type="number" step="any"
                               inputmode="decimal" placeholder="0"
                               @bind="row.MeterValue" />
                        <input class="form-control form-control-sm fuel-log-gallons"
                               type="text" readonly tabindex="-1"
                               value="@(gallons.HasValue ? gallons.Value.ToString("0.##") : "—")" />
                        @if (isStartRow)
                        {
                            <span></span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger fuel-log-remove"
                                    @onclick="() => RemoveRow(index)"
                                    title="Remove row">×</button>
                        }
                    </div>
                }
            </div>

            <div class="fuel-log-actions">
                <button class="btn btn-sm btn-outline-secondary" @onclick="AddRow">+ Add row</button>
                <button class="btn btn-sm btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @(_saving ? "Saving…" : "Save fuel log")
                </button>
                <button class="btn btn-sm btn-outline-warning" @onclick="StartNewLogAsync" disabled="@_saving">
                    Start new log
                </button>
                @if (!string.IsNullOrEmpty(_statusMessage))
                {
                    <span class="@(_statusSuccess ? "text-success" : "text-warning") fuel-log-savemsg">
                        @_statusMessage
                    </span>
                }
            </div>

            <div class="fuel-log-total">
                Total gallons pumped: <strong>@TotalGallons().ToString("0.##")</strong>
            </div>
        }
    </div>
</div>

@code {
    // Editable view of a single log row. GallonsPumped isn't stored here —
    // it's always derived from this row's and the previous row's meter values
    // via GallonsForRow, which is what makes the column auto-fill.
    private sealed class FuelLogRow
    {
        // Stable identity so Blazor keeps each row's inputs bound to the right
        // row when one is removed from the middle of the list.
        public Guid Key { get; } = Guid.NewGuid();
        public string Id { get; set; } = string.Empty;
        public string EquipmentNumber { get; set; } = string.Empty;
        public decimal? MeterValue { get; set; }
    }

    private readonly List<FuelLogRow> _rows = new();
    private bool _loading = true;
    private bool _saving;
    private bool _listening;
    private string? _statusMessage;
    private bool _statusSuccess;

    // Snapshot of the rows as they last matched what's persisted (taken after
    // load and after a successful save). The grid is "dirty" when the current
    // rows differ from it — that's what triggers the save prompt on New Log.
    private string _savedSignature = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var entries = await FuelLogApi.GetFuelLogAsync();
        foreach (var entry in entries.OrderBy(entry => entry.SortOrder))
        {
            _rows.Add(new FuelLogRow
            {
                Id = entry.Id,
                EquipmentNumber = entry.EquipmentNumber,
                MeterValue = entry.MeterValue
            });
        }

        EnsureStartRow();
        _savedSignature = CurrentSignature();

        _loading = false;
    }

    // Order-sensitive fingerprint of the rows' editable content. Gallons is
    // derived, so only the equipment number and meter value matter for whether
    // the driver has unsaved changes.
    private string CurrentSignature() =>
        string.Join("\n", _rows.Select(row => $"{row.EquipmentNumber}|{row.MeterValue}"));

    private bool IsDirty => CurrentSignature() != _savedSignature;

    // Row 0 is always the "Start" baseline: a read-only label plus the meter
    // reading the driver began at (0 when starting fresh). It anchors the
    // gallons calc so the first real entry's gallons = its meter − the start
    // meter. We also keep at least one entry row beneath it to type into.
    private void EnsureStartRow()
    {
        if (_rows.Count == 0)
            _rows.Add(new FuelLogRow { EquipmentNumber = "Start", MeterValue = 0 });
        else
            _rows[0].EquipmentNumber = "Start";

        if (_rows.Count < 2)
            _rows.Add(new FuelLogRow());
    }

    // Gallons for a row = this row's meter − the previous row's meter, when
    // both readings are present. The first row (or any row missing a value)
    // has nothing to subtract from, so it returns null and renders an em dash.
    private decimal? GallonsForRow(int index)
    {
        if (index <= 0) return null;

        var currentMeter = _rows[index].MeterValue;
        var previousMeter = _rows[index - 1].MeterValue;
        if (currentMeter is null || previousMeter is null) return null;

        return currentMeter.Value - previousMeter.Value;
    }

    // Sum of the positive per-row gallons. Negative values (a meter reading
    // lower than the one above it — usually a typo) are left out of the total.
    private decimal TotalGallons()
    {
        decimal total = 0;
        for (var index = 0; index < _rows.Count; index++)
        {
            var gallons = GallonsForRow(index);
            if (gallons.HasValue && gallons.Value > 0) total += gallons.Value;
        }
        return total;
    }

    private void AddRow()
    {
        _rows.Add(new FuelLogRow());
        _statusMessage = null;
    }

    // Voice-capture the next meter reading and drop it into the next empty
    // meter box. "Next open" = the first row (top-down) whose meter is still
    // blank; if every row is filled we append a fresh one so the spoken value
    // isn't lost. The driver still types the equipment number themselves.
    private async Task LogNextAsync()
    {
        _listening = true;
        _statusMessage = null;
        StateHasChanged();

        var spoken = await SpeechService.DictateAsync();

        _listening = false;

        if (string.IsNullOrWhiteSpace(spoken))
        {
            _statusSuccess = false;
            _statusMessage = "Didn't catch a meter reading — tap Log Next to try again.";
            return;
        }

        var meterValue = ParseMeterValue(spoken);
        if (meterValue is null)
        {
            _statusSuccess = false;
            _statusMessage = $"Couldn't read a number from \"{spoken}\".";
            return;
        }

        var targetRow = _rows.FirstOrDefault(row => row.MeterValue is null);
        if (targetRow is null)
        {
            targetRow = new FuelLogRow();
            _rows.Add(targetRow);
        }

        targetRow.MeterValue = meterValue;
        _statusSuccess = true;
        _statusMessage = $"Logged meter {meterValue.Value.ToString("0.##")}.";
    }

    // Pull the first numeric run out of the spoken text. Speech usually comes
    // back as plain digits ("104") but can carry grouping commas ("1,040") or
    // trailing words ("104 gallons"), so strip commas and match the first
    // number rather than parsing the whole string.
    private static decimal? ParseMeterValue(string spoken)
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            spoken.Replace(",", string.Empty), @"-?\d+(\.\d+)?");
        if (!match.Success) return null;

        return decimal.TryParse(
            match.Value,
            System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture,
            out var value)
            ? value
            : null;
    }

    private void RemoveRow(int index)
    {
        // Index 0 is the Start baseline and can't be removed.
        if (index <= 0 || index >= _rows.Count) return;

        _rows.RemoveAt(index);
        if (_rows.Count < 2) _rows.Add(new FuelLogRow());
        _statusMessage = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _statusMessage = null;
        StateHasChanged();

        var saveDto = new SaveFuelLogDto
        {
            Entries = _rows.Select((row, index) => new FuelLogEntryDto
            {
                Id = row.Id,
                EquipmentNumber = row.EquipmentNumber?.Trim() ?? string.Empty,
                MeterValue = row.MeterValue ?? 0,
                GallonsPumped = GallonsForRow(index) ?? 0,
                SortOrder = index
            }).ToList()
        };

        var saved = await FuelLogApi.SaveFuelLogAsync(saveDto);

        _saving = false;
        _statusSuccess = saved;
        _statusMessage = saved ? "Saved." : "Save failed — try again.";
        if (saved) _savedSignature = CurrentSignature();
    }

    // Clear the grid back to a fresh log (Start baseline + one empty entry).
    // If there are unsaved changes, give the driver the chance to save them
    // first so a stray click can't wipe out un-persisted work. This resets the
    // working area only; the previously saved log stays on the server until a
    // new one is saved over it.
    private async Task StartNewLogAsync()
    {
        if (IsDirty)
        {
            var saveFirst = await JS.InvokeAsync<bool>(
                "confirm",
                "This fuel log has unsaved changes.\n\n" +
                "OK — save them first, then start a new log.\n" +
                "Cancel — discard them and start a new log.");

            if (saveFirst)
            {
                await SaveAsync();
                // If the save didn't go through, keep the rows so nothing is lost.
                if (!_statusSuccess) return;
            }
        }

        _rows.Clear();
        EnsureStartRow();
        _savedSignature = CurrentSignature();
        _statusSuccess = true;
        _statusMessage = "Started a new fuel log.";
    }
}
